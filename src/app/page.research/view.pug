nav(class="sticky top-0 z-20 bg-white shadow")
    div(class="max-w-6xl px-4 sm:px-6 lg:px-8 py-3")
        div(class="flex items-center justify-between")
            h1(class="flex text-lg font-semibold text-zinc-950 gap-x-3 items-center")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-6 text-amber-600")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18")
                span 연구 주제 발굴

            //- Collection Selector
            div(class="flex items-center gap-3")
                div(*ngIf="collections.length > 0", class="flex items-center gap-2")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4 text-gray-400")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125")
                    select([(ngModel)]="selectedCollection", (ngModelChange)="onCollectionChange()", class="px-3 py-1.5 rounded-lg border border-gray-300 text-[12px] bg-white focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none min-w-[200px]")
                        option(*ngFor="let col of collections", [value]="col.name") {{col.name}} ({{col.total_docs}}문서 · {{col.short_name}})
                button((click)="loadCollections()", class="flex items-center justify-center w-7 h-7 rounded-lg text-gray-400 hover:text-amber-600 hover:bg-amber-50 transition-colors", title="컬렉션 새로고침")
                    svg(*ngIf="!collectionsLoading", xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-3.5")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182")
                    svg(*ngIf="collectionsLoading", class="animate-spin size-3.5", viewBox="0 0 24 24")
                        circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                        path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")

div(class="max-w-6xl pt-6 px-4 sm:px-6 lg:px-8 pb-8 space-y-6")

    //- Empty Collections Warning
    div(*ngIf="!collectionsLoading && collections.length === 0", class="bg-amber-50 rounded-xl border border-amber-200 p-8 text-center")
        div(class="flex flex-col items-center gap-3")
            div(class="flex items-center justify-center w-12 h-12 rounded-xl bg-amber-100 text-amber-600")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-6")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125")
            h3(class="text-[15px] font-semibold text-amber-900") 컬렉션이 없습니다
            p(class="text-[13px] text-amber-700 max-w-md") 연구 주제 발굴을 위해서는 먼저 논문 PDF를 임베딩해야 합니다. 임베딩 페이지에서 컬렉션을 생성하고 PDF를 업로드하세요.
            a(href="/embedding", class="inline-flex items-center gap-2 mt-2 px-4 py-2 rounded-lg bg-amber-600 text-white text-[13px] font-medium hover:bg-amber-500 transition-colors")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3")
                | 임베딩 페이지로 이동

    //- Collection Info Card
    div(*ngIf="collections.length > 0 && getCollectionInfo()", class="bg-gradient-to-r from-amber-50 to-orange-50 rounded-xl border border-amber-100 px-6 py-4")
        div(class="flex items-center justify-between")
            div(class="flex items-center gap-4")
                div(class="flex items-center justify-center w-10 h-10 rounded-xl bg-amber-100 text-amber-600")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125")
                div
                    div(class="text-[14px] font-semibold text-gray-900") {{getCollectionInfo().name}}
                    div(class="text-[12px] text-gray-500 mt-0.5") 현재 선택된 분석 대상 컬렉션
            div(class="flex items-center gap-5")
                div(class="text-center")
                    div(class="text-[18px] font-bold text-amber-700") {{getCollectionInfo().total_docs}}
                    div(class="text-[10px] text-gray-500 uppercase tracking-wider") 문서
                div(class="text-center")
                    div(class="text-[18px] font-bold text-amber-700") {{getCollectionInfo().total_chunks}}
                    div(class="text-[10px] text-gray-500 uppercase tracking-wider") 청크
                div(class="text-center")
                    span(class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-1 text-[11px] font-medium text-amber-800") {{getCollectionInfo().short_name}} · {{getCollectionInfo().dim}}D

    //- ============================================================
    //- Tab Navigation
    //- ============================================================
    div(*ngIf="collections.length > 0", class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden")
        div(class="border-b border-gray-200 px-2")
            nav(class="flex gap-0.5 -mb-px overflow-x-auto")
                button(*ngFor="let tab of tabs", (click)="switchTab(tab.id)", class="inline-flex items-center gap-1.5 px-4 py-3 text-[12px] font-medium border-b-2 transition-all whitespace-nowrap", [ngClass]="activeTab === tab.id ? 'border-amber-500 text-amber-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4")
                        path(stroke-linecap="round", stroke-linejoin="round", [attr.d]="tab.icon")
                    | {{tab.label}}

        //- ============================================================
        //- TAB: 주제 탐색
        //- ============================================================
        div(*ngIf="activeTab === 'discover'")
            //- Search Input
            div(class="px-6 py-5 border-b border-gray-100")
                h2(class="text-[15px] font-semibold text-gray-900") 키워드 기반 주제 탐색
                p(class="mt-1 text-[13px] text-gray-500") 연구 키워드를 입력하면 Milvus에 저장된 논문 벡터에서 유사 문서를 탐색하고, 새로운 연구 주제를 추천합니다.

                div(class="mt-4 flex gap-3")
                    div(class="flex-1 relative")
                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400")
                            path(stroke-linecap="round", stroke-linejoin="round", d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z")
                        input(type="text", [(ngModel)]="searchKeyword", placeholder="예: 플라즈마 에칭 균일도, RF 방전 특성, 박막 증착 온도...", class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none transition-all", (keyup.enter)="searchAndRecommend()")
                    button((click)="search()", [disabled]="searching", class="inline-flex items-center gap-2 rounded-lg bg-amber-600 px-5 py-2.5 text-[13px] font-semibold text-white shadow-sm hover:bg-amber-500 disabled:opacity-50 transition-all active:scale-95")
                        svg(class="animate-spin size-4", viewBox="0 0 24 24", *ngIf="searching")
                            circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                            path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                        | 탐색
                    button((click)="recommend()", [disabled]="recommending || !searchKeyword.trim()", class="inline-flex items-center gap-2 rounded-lg bg-violet-600 px-5 py-2.5 text-[13px] font-semibold text-white shadow-sm hover:bg-violet-500 disabled:opacity-50 transition-all active:scale-95")
                        svg(class="animate-spin size-4", viewBox="0 0 24 24", *ngIf="recommending")
                            circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                            path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4", *ngIf="!recommending")
                            path(stroke-linecap="round", stroke-linejoin="round", d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z")
                        | 주제 추천

                //- Quick Keyword Tags
                div(class="mt-3 flex flex-wrap gap-2")
                    span(class="text-[11px] text-gray-400 leading-6") 추천:
                    button(*ngFor="let tag of suggestedTags", (click)="searchKeyword = tag; searchAndRecommend()", class="inline-flex items-center rounded-full bg-amber-50 border border-amber-200 px-2.5 py-0.5 text-[11px] font-medium text-amber-700 hover:bg-amber-100 transition-colors cursor-pointer") {{tag}}

            //- Topic Recommendations
            div(*ngIf="recommending || recommendations.length > 0")
                div(class="px-6 py-4 border-b border-gray-100")
                    div(class="flex items-center justify-between")
                        div(class="flex items-center gap-3")
                            div(class="w-8 h-8 rounded-lg bg-violet-100 flex items-center justify-center")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5 text-violet-600")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z")
                            div
                                h2(class="text-[15px] font-semibold text-gray-900") 새로운 연구 주제 추천
                                p(class="text-[12px] text-gray-400 mt-0.5", *ngIf="recommendKeyword") "{{recommendKeyword}}" 기반 분석
                        div(class="flex gap-2", *ngIf="!recommending && recommendations.length > 0")
                            span(*ngIf="recommendStats.cross_topic > 0", class="inline-flex items-center rounded-full bg-violet-100 px-2 py-0.5 text-[10px] font-medium text-violet-700") 교차 {{recommendStats.cross_topic}}
                            span(*ngIf="recommendStats.research_gap > 0", class="inline-flex items-center rounded-full bg-rose-100 px-2 py-0.5 text-[10px] font-medium text-rose-700") 공백 {{recommendStats.research_gap}}
                            span(*ngIf="recommendStats.expansion > 0", class="inline-flex items-center rounded-full bg-sky-100 px-2 py-0.5 text-[10px] font-medium text-sky-700") 확장 {{recommendStats.expansion}}

                //- Loading
                div(*ngIf="recommending", class="px-6 py-12")
                    div(class="flex flex-col items-center justify-center gap-3")
                        svg(class="animate-spin size-8 text-violet-600", viewBox="0 0 24 24")
                            circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                            path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                        p(class="text-[13px] text-gray-500 font-medium") 연구 주제를 분석하고 있습니다...

                //- Recommendation Cards
                div(*ngIf="!recommending && recommendations.length > 0", class="divide-y divide-gray-100")
                    div(*ngFor="let rec of recommendations; let i = index", class="px-6 py-4 hover:bg-gray-50/50 transition-colors cursor-pointer", (click)="toggleRec(i)")
                        div(class="flex items-start gap-4")
                            div(class="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center", [ngClass]="{'bg-violet-50': rec.type === 'cross_topic', 'bg-rose-50': rec.type === 'research_gap', 'bg-sky-50': rec.type === 'expansion'}")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5", [ngClass]="{'text-violet-600': rec.type === 'cross_topic', 'text-rose-600': rec.type === 'research_gap', 'text-sky-600': rec.type === 'expansion'}")
                                    path(stroke-linecap="round", stroke-linejoin="round", [attr.d]="getTypeIcon(rec.type)")
                            div(class="flex-1 min-w-0")
                                div(class="flex items-center gap-2 mb-1")
                                    span(class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold", [ngClass]="getTypeColor(rec.type)") {{getTypeLabel(rec.type)}}
                                    span(*ngIf="rec.category", class="text-[10px] text-gray-400") {{rec.category}}
                                h3(class="text-[14px] font-semibold text-gray-900") {{rec.title}}
                                p(class="text-[12px] text-gray-500 mt-1 leading-relaxed") {{rec.description}}
                            div(class="flex-shrink-0 text-right")
                                div(class="text-[11px] text-gray-400 mb-1") 관련도
                                div(class="flex items-center gap-1")
                                    div(class="w-14 bg-gray-200 rounded-full h-1.5")
                                        div(class="h-1.5 rounded-full transition-all", [ngClass]="{'bg-violet-500': rec.type === 'cross_topic', 'bg-rose-500': rec.type === 'research_gap', 'bg-sky-500': rec.type === 'expansion'}", [style.width.%]="rec.relevance * 100")
                                    span(class="text-[12px] font-mono text-gray-600 w-12 text-right") {{(rec.relevance * 100).toFixed(1)}}%

                        //- Expanded Evidence
                        div(*ngIf="expandedRec === i && rec.evidence && rec.evidence.length > 0", class="mt-3 ml-13 space-y-2", (click)="$event.stopPropagation()")
                            div(class="text-[11px] text-gray-400 font-medium mb-2 flex items-center gap-1")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-3")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z")
                                | 근거 문헌
                            div(*ngFor="let ev of rec.evidence", class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-100")
                                div(class="flex items-center gap-2 mb-1")
                                    span(class="inline-flex items-center rounded bg-blue-50 px-1.5 py-0.5 text-[10px] font-medium text-blue-700") {{ev.filename}}
                                    span(class="text-[10px] font-mono", [ngClass]="{'text-green-600': ev.score > 0.5, 'text-amber-600': ev.score <= 0.5}") {{(ev.score * 100).toFixed(1)}}%
                                p(class="text-[12px] text-gray-600 leading-relaxed line-clamp-3") {{ev.text}}

            //- Search Results
            div(*ngIf="searchResults.length > 0")
                div(class="px-6 py-4 border-b border-gray-100")
                    div(class="flex items-center justify-between")
                        div
                            h2(class="text-[15px] font-semibold text-gray-900") 탐색 결과
                            p(class="text-[12px] text-gray-400 mt-0.5") "{{lastKeyword}}" 관련 문서 {{searchResults.length}}건
                        span(class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-[11px] font-medium text-green-700") {{totalHits}}개 매칭

                div(class="divide-y divide-gray-100")
                    div(*ngFor="let cluster of searchResults; let i = index", class="px-6 py-5 hover:bg-gray-50/50 transition-colors")
                        div(class="flex items-start justify-between")
                            div(class="flex-1 min-w-0")
                                div(class="flex items-center gap-2 mb-1")
                                    span(class="inline-flex items-center rounded-md bg-blue-50 px-2 py-0.5 text-[11px] font-medium text-blue-700") {{cluster.filename}}
                                    span(class="text-[11px] text-gray-400") {{cluster.chunks.length}}개 청크 매칭
                                div(class="flex items-center gap-2 mt-1")
                                    div(class="text-[12px] font-medium text-gray-700") 최대 유사도
                                    div(class="flex items-center gap-1")
                                        div(class="w-20 bg-gray-200 rounded-full h-1.5")
                                            div(class="bg-green-500 h-1.5 rounded-full", [style.width.%]="cluster.max_score * 100")
                                        span(class="text-[12px] font-mono text-green-600") {{(cluster.max_score * 100).toFixed(1)}}%
                            button((click)="findRelated(cluster.doc_id)", class="text-[12px] text-amber-600 hover:text-amber-500 font-medium flex items-center gap-1 ml-4")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-3.5")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244")
                                | 관련 연구

                        div(class="mt-3 space-y-2")
                            div(*ngFor="let chunk of cluster.chunks.slice(0, 3)", class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-100")
                                div(class="flex items-center gap-2 mb-1")
                                    span(class="text-[10px] text-gray-400 font-mono") chunk {{chunk.chunk_index}}
                                    span(class="text-[10px] text-green-600 font-mono") {{(chunk.score * 100).toFixed(1)}}%
                                p(class="text-[12px] text-gray-600 leading-relaxed line-clamp-3") {{chunk.text}}

            //- Related Documents
            div(*ngIf="relatedDocs.length > 0")
                div(class="px-6 py-4 border-b border-gray-100")
                    h2(class="text-[15px] font-semibold text-gray-900") 관련 연구 문서
                    p(class="text-[12px] text-gray-400 mt-0.5") "{{relatedSource}}" 기반 유사 문서
                div(class="divide-y divide-gray-100")
                    div(*ngFor="let doc of relatedDocs; let i = index", class="px-6 py-4 flex items-center gap-4 hover:bg-gray-50 transition-colors")
                        div(class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center bg-amber-50 text-amber-600 text-[12px] font-bold") {{i + 1}}
                        div(class="flex-1 min-w-0")
                            p(class="text-[13px] font-medium text-gray-900 truncate") {{doc.filename}}
                            p(class="text-[12px] text-gray-500 mt-0.5 line-clamp-2") {{doc.snippet}}
                        div(class="flex items-center gap-1 flex-shrink-0")
                            div(class="w-16 bg-gray-200 rounded-full h-1.5")
                                div(class="bg-amber-500 h-1.5 rounded-full", [style.width.%]="doc.score * 100")
                            span(class="text-[12px] font-mono text-amber-600 w-12 text-right") {{(doc.score * 100).toFixed(1)}}%

            //- Empty state
            div(*ngIf="!searching && !recommending && searchResults.length === 0 && recommendations.length === 0", class="px-6 py-16 text-center")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-10 text-gray-300 mx-auto mb-3")
                    path(stroke-linecap="round", stroke-linejoin="round", d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z")
                p(class="text-[13px] text-gray-500") 키워드를 입력하고 탐색 또는 주제 추천 버튼을 클릭하세요.
                p(class="text-[11px] text-gray-400 mt-1") 추천 태그를 클릭하면 빠르게 시작할 수 있습니다.

        //- ============================================================
        //- TAB: 토픽 맵
        //- ============================================================
        div(*ngIf="activeTab === 'topicmap'")
            div(class="px-6 py-4 border-b border-gray-100 flex items-center justify-between")
                div
                    h2(class="text-[15px] font-semibold text-gray-900") 토픽 맵
                    p(class="text-[12px] text-gray-400 mt-0.5") 문서 벡터를 클러스터링하여 연구 주제 분포를 시각화합니다
                div(class="flex items-center gap-3")
                    div(*ngIf="topicMapLoaded && !topicLoading", class="flex items-center gap-2")
                        span(class="inline-flex items-center rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-medium text-emerald-700") {{topicNClusters}}개 토픽
                        span(class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-600") {{topicTotalDocs}}문서
                    button((click)="loadTopicMap()", [disabled]="topicLoading", class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-600 px-4 py-2 text-[12px] font-semibold text-white shadow-sm hover:bg-emerald-500 disabled:opacity-50 transition-all active:scale-95")
                        svg(class="animate-spin size-3.5", viewBox="0 0 24 24", *ngIf="topicLoading")
                            circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                            path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                        svg(*ngIf="!topicLoading", xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-3.5")
                            path(stroke-linecap="round", stroke-linejoin="round", d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z")
                        | {{topicMapLoaded ? '다시 분석' : '분석 실행'}}

            //- Topic Map Loading
            div(*ngIf="topicLoading", class="px-6 py-16")
                div(class="flex flex-col items-center justify-center gap-3")
                    svg(class="animate-spin size-8 text-emerald-600", viewBox="0 0 24 24")
                        circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                        path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                    p(class="text-[13px] text-gray-500 font-medium") 토픽 클러스터링 분석 중...
                    p(class="text-[11px] text-gray-400") HDBSCAN 클러스터링 · UMAP 차원 축소 · 키워드 추출

            //- Topic Map Empty
            div(*ngIf="!topicLoading && !topicMapLoaded", class="px-6 py-16 text-center")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-10 text-gray-300 mx-auto mb-3")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z")
                p(class="text-[13px] text-gray-500") '분석 실행' 버튼을 클릭하여 문서 벡터의 토픽 분포를 시각화하세요.
                p(class="text-[11px] text-gray-400 mt-1") HDBSCAN 클러스터링과 UMAP 2D 투영을 사용합니다.

            //- Topic Map Content
            div(*ngIf="!topicLoading && topicMapLoaded")
                div(class="px-6 pt-4 pb-2")
                    div(class="relative bg-gray-50 rounded-lg border border-gray-200 overflow-hidden", style="height: 380px")
                        canvas(#topicCanvas="", class="w-full h-full cursor-crosshair", (mousemove)="onCanvasMouseMove($event)", (mouseleave)="onCanvasMouseLeave()", (click)="onCanvasClick($event)")
                        div(*ngIf="hoveredPoint", class="absolute top-3 right-3 bg-white rounded-lg shadow-lg border border-gray-200 px-3 py-2 pointer-events-none z-10")
                            div(class="flex items-center gap-2 mb-1")
                                div(class="w-2.5 h-2.5 rounded-full", [style.background]="hoveredPoint.color")
                                span(class="text-[11px] font-medium text-gray-700") {{hoveredPoint.filename}}
                            div(class="text-[10px] text-gray-400") 클러스터: {{hoveredPoint.cluster_id >= 0 ? '토픽 ' + (hoveredPoint.cluster_id + 1) : '미분류'}}

                div(class="px-6 py-3 flex flex-wrap gap-2 border-t border-gray-100")
                    button((click)="selectCluster(-2)", class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[11px] font-medium transition-all", [ngClass]="selectedCluster === -2 ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'")
                        | 전체 ({{topicTotalDocs}})
                    button(*ngFor="let cluster of topicClusters", (click)="selectCluster(cluster.id)", class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[11px] font-medium transition-all", [ngClass]="selectedCluster === cluster.id ? 'text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'", [style.background]="selectedCluster === cluster.id ? cluster.color : ''")
                        div(class="w-2 h-2 rounded-full", [style.background]="cluster.color", *ngIf="selectedCluster !== cluster.id")
                        | {{cluster.label}} ({{cluster.doc_count}})

                div(class="px-6 pb-5 space-y-3")
                    div(*ngFor="let cluster of topicClusters", class="rounded-lg border transition-all", [ngClass]="selectedCluster === -2 || selectedCluster === cluster.id ? 'border-gray-200 bg-white' : 'border-transparent bg-gray-50/50 opacity-40'", [class.hidden]="selectedCluster !== -2 && selectedCluster !== cluster.id")
                        div(class="px-4 py-3 cursor-pointer", (click)="selectCluster(cluster.id)")
                            div(class="flex items-center justify-between")
                                div(class="flex items-center gap-3")
                                    div(class="w-3 h-3 rounded-full flex-shrink-0", [style.background]="cluster.color")
                                    div
                                        div(class="text-[13px] font-semibold text-gray-900") {{cluster.label}}
                                        div(class="text-[11px] text-gray-400 mt-0.5") {{cluster.doc_count}}개 문서
                                span(class="text-[10px] text-gray-400 font-mono") 밀도 {{cluster.density.toFixed(1)}}
                            div(class="mt-2 flex flex-wrap gap-1.5", *ngIf="cluster.keywords.length > 0")
                                span(*ngFor="let kw of cluster.keywords", class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium border", [style.borderColor]="cluster.color + '40'", [style.backgroundColor]="cluster.color + '10'", [style.color]="cluster.color") {{kw.term}}
                        div(*ngIf="selectedCluster === cluster.id", class="border-t border-gray-100 px-4 py-3")
                            div(*ngIf="cluster.representative_snippet", class="mb-3")
                                div(class="text-[11px] text-gray-400 font-medium mb-1") 대표 문서 요약
                                div(class="bg-emerald-50/50 rounded-lg px-3 py-2 border border-emerald-100")
                                    div(class="text-[10px] text-emerald-600 font-medium mb-0.5") {{cluster.representative_doc}}
                                    p(class="text-[11px] text-gray-600 leading-relaxed line-clamp-3") {{cluster.representative_snippet}}
                            div(class="text-[11px] text-gray-400 font-medium mb-2") 포함 문서
                            div(class="space-y-1.5")
                                div(*ngFor="let doc of cluster.docs; let di = index", class="flex items-center gap-2 px-3 py-2 rounded-md bg-gray-50 hover:bg-gray-100 transition-colors")
                                    div(class="w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-bold text-white flex-shrink-0", [style.background]="cluster.color") {{di + 1}}
                                    span(class="text-[12px] text-gray-700 truncate") {{doc.filename}}
                                    button((click)="searchKeyword = doc.filename.replace('.pdf',''); switchTab('discover'); searchAndRecommend(); $event.stopPropagation()", class="ml-auto text-[10px] text-amber-600 hover:text-amber-500 font-medium flex-shrink-0") 탐색

                //- Interpretation Panel
                div(*ngIf="topicInterpretation", class="border-t border-gray-100")
                    //- Summary
                    div(class="px-6 py-4")
                        div(class="rounded-xl bg-gradient-to-r from-emerald-50 to-teal-50 border border-emerald-200 px-5 py-4")
                            div(class="flex items-center gap-2 mb-2")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4 text-emerald-600")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605")
                                span(class="text-[13px] font-semibold text-emerald-800") 토픽 맵 해석
                            p(class="text-[12px] text-emerald-700 leading-relaxed") {{topicInterpretation.summary}}

                    //- Cluster Relationships
                    div(*ngIf="topicInterpretation.relationships && topicInterpretation.relationships.length > 0", class="px-6 pb-4")
                        div(class="text-[13px] font-semibold text-gray-700 mb-3 flex items-center gap-2")
                            svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4 text-gray-500")
                                path(stroke-linecap="round", stroke-linejoin="round", d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5")
                            | 클러스터 간 관계
                        div(class="grid grid-cols-1 sm:grid-cols-2 gap-2")
                            div(*ngFor="let rel of topicInterpretation.relationships.slice(0, 8)", class="flex items-center gap-3 rounded-lg border px-4 py-3 bg-white transition-colors cursor-pointer hover:bg-gray-50", [ngClass]="{'border-emerald-200 bg-emerald-50/30': rel.relation === 'similar', 'border-amber-200 bg-amber-50/20': rel.relation === 'related', 'border-gray-200': rel.relation === 'distinct'}", (click)="selectCluster(rel.cluster_a)")
                                div(class="flex items-center gap-2 flex-1 min-w-0")
                                    div(class="w-3 h-3 rounded-full flex-shrink-0", [style.background]="rel.color_a")
                                    span(class="text-[12px] font-medium text-gray-700 truncate") {{rel.label_a}}
                                div(class="flex items-center gap-1 flex-shrink-0 px-2")
                                    div(class="w-8 h-0.5 rounded-full", [ngClass]="{'bg-emerald-400': rel.relation === 'similar', 'bg-amber-300': rel.relation === 'related', 'bg-gray-200': rel.relation === 'distinct'}")
                                    span(class="text-[10px] font-mono", [ngClass]="{'text-emerald-600': rel.relation === 'similar', 'text-amber-600': rel.relation === 'related', 'text-gray-400': rel.relation === 'distinct'}") {{(rel.cosine_similarity * 100).toFixed(0)}}%
                                div(class="flex items-center gap-2 flex-1 min-w-0 justify-end")
                                    span(class="text-[12px] font-medium text-gray-700 truncate") {{rel.label_b}}
                                    div(class="w-3 h-3 rounded-full flex-shrink-0", [style.background]="rel.color_b")

                    //- Bridge Documents
                    div(*ngIf="topicInterpretation.bridge_docs && topicInterpretation.bridge_docs.length > 0", class="px-6 pb-5")
                        div(class="text-[13px] font-semibold text-gray-700 mb-3 flex items-center gap-2")
                            svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4 text-gray-500")
                                path(stroke-linecap="round", stroke-linejoin="round", d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244")
                            | 브릿지 문서 (교차 영역)
                        div(class="space-y-2")
                            div(*ngFor="let bdoc of topicInterpretation.bridge_docs", class="flex items-center gap-3 rounded-lg border border-gray-200 px-4 py-3 bg-white hover:bg-gray-50 transition-colors")
                                div(class="flex-1 min-w-0")
                                    div(class="text-[12px] font-medium text-gray-900 truncate") {{bdoc.filename}}
                                    div(class="flex items-center gap-2 mt-1")
                                        div(class="flex items-center gap-1")
                                            div(class="w-2 h-2 rounded-full", [style.background]="bdoc.primary_cluster.color")
                                            span(class="text-[10px] text-gray-500") {{bdoc.primary_cluster.label}} ({{(bdoc.primary_cluster.similarity * 100).toFixed(0)}}%)
                                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-3 text-gray-300")
                                            path(stroke-linecap="round", stroke-linejoin="round", d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5")
                                        div(class="flex items-center gap-1")
                                            div(class="w-2 h-2 rounded-full", [style.background]="bdoc.secondary_cluster.color")
                                            span(class="text-[10px] text-gray-500") {{bdoc.secondary_cluster.label}} ({{(bdoc.secondary_cluster.similarity * 100).toFixed(0)}}%)
                                button((click)="searchKeyword = bdoc.filename.replace('.pdf',''); switchTab('discover'); searchAndRecommend()", class="text-[10px] text-amber-600 hover:text-amber-500 font-medium flex-shrink-0") 탐색

        //- ============================================================
        //- TAB: Research Gap Detector
        //- ============================================================
        div(*ngIf="activeTab === 'gap'")
            div(class="px-6 py-5 border-b border-gray-100")
                h2(class="text-[15px] font-semibold text-gray-900") Research Gap Detector
                p(class="mt-1 text-[13px] text-gray-500") 키워드 조합의 벡터 공간 밀도를 분석하여 연구가 부족한 교차 영역(연구 공백)을 탐지합니다.

                div(class="mt-4 flex gap-3")
                    div(class="flex-1 relative")
                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400")
                            path(stroke-linecap="round", stroke-linejoin="round", d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z")
                        input(type="text", [(ngModel)]="gapKeywords", placeholder="분석할 키워드를 쉼표로 구분하여 입력 (예: 플라즈마, 에칭, 균일도)", class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none transition-all", (keyup.enter)="analyzeGaps()")
                    button((click)="analyzeGaps()", [disabled]="gapLoading || !gapKeywords.trim()", class="inline-flex items-center gap-2 rounded-lg bg-rose-600 px-5 py-2.5 text-[13px] font-semibold text-white shadow-sm hover:bg-rose-500 disabled:opacity-50 transition-all active:scale-95")
                        svg(class="animate-spin size-4", viewBox="0 0 24 24", *ngIf="gapLoading")
                            circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                            path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                        svg(*ngIf="!gapLoading", xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                            path(stroke-linecap="round", stroke-linejoin="round", d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z")
                        | Gap 분석

                div(class="mt-3 flex flex-wrap gap-2")
                    span(class="text-[11px] text-gray-400 leading-6") 추천 조합:
                    button(*ngFor="let tag of gapSuggestedTags", (click)="gapKeywords = tag; analyzeGaps()", class="inline-flex items-center rounded-full bg-rose-50 border border-rose-200 px-2.5 py-0.5 text-[11px] font-medium text-rose-700 hover:bg-rose-100 transition-colors cursor-pointer") {{tag}}

            //- Loading
            div(*ngIf="gapLoading", class="px-6 py-16")
                div(class="flex flex-col items-center justify-center gap-3")
                    svg(class="animate-spin size-8 text-rose-600", viewBox="0 0 24 24")
                        circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                        path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                    p(class="text-[13px] text-gray-500 font-medium") 벡터 공간 밀도 분석 중...
                    p(class="text-[11px] text-gray-400") KNN 밀도 분석 · 교차 영역 비교 · 연구 공백 탐지

            //- Gap Results
            div(*ngIf="!gapLoading && gapAnalyzed")
                //- Keyword Density Overview
                div(*ngIf="gapKeywordDensities.length > 0", class="px-6 py-4 border-b border-gray-100")
                    div(class="text-[13px] font-semibold text-gray-700 mb-3") 키워드별 밀도 분석
                    div(class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3")
                        div(*ngFor="let kd of gapKeywordDensities", class="rounded-lg border border-gray-200 px-4 py-3 bg-white")
                            div(class="flex items-center justify-between mb-2")
                                span(class="text-[13px] font-medium text-gray-900") {{kd.keyword}}
                                span(class="text-[11px] font-mono text-gray-500") {{kd.doc_count}}문서
                            div(class="flex items-center gap-2")
                                div(class="flex-1 bg-gray-200 rounded-full h-2")
                                    div(class="h-2 rounded-full transition-all", [ngClass]="getDensityColor(kd.density)", [style.width.%]="getDensityBarWidth(kd.density)")
                                span(class="text-[12px] font-mono w-12 text-right", [ngClass]="{'text-green-600': kd.density >= 0.5, 'text-amber-600': kd.density >= 0.3 && kd.density < 0.5, 'text-rose-600': kd.density < 0.3}") {{(kd.density * 100).toFixed(0)}}%
                            div(class="text-[10px] text-gray-400 mt-1") 밀도 {{kd.density >= 0.5 ? '높음 — 충분히 연구됨' : kd.density >= 0.3 ? '보통 — 추가 연구 여지' : '낮음 — 연구 부족'}}

                //- Gap Cards
                div(*ngIf="gapResults.length > 0", class="divide-y divide-gray-100")
                    div(class="px-6 py-3 bg-gray-50")
                        div(class="flex items-center justify-between")
                            span(class="text-[13px] font-semibold text-gray-700") 탐지된 연구 공백
                            span(class="text-[11px] text-gray-400") {{gapResults.length}}건

                    div(*ngFor="let gap of gapResults; let gi = index", class="px-6 py-4 hover:bg-gray-50/50 transition-colors cursor-pointer", (click)="toggleGap(gi)")
                        div(class="flex items-start gap-4")
                            div(class="flex-shrink-0 w-9 h-9 rounded-lg bg-rose-50 flex items-center justify-center")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5 text-rose-600")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z")
                            div(class="flex-1 min-w-0")
                                div(class="flex items-center gap-2 mb-1")
                                    span(*ngFor="let kw of gap.keywords", class="inline-flex items-center rounded-full bg-rose-100 px-2 py-0.5 text-[10px] font-semibold text-rose-700") {{kw}}
                                    span(class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold", [ngClass]="getPotentialColor(gap.potential)") 잠재력: {{gap.potential}}
                                p(class="text-[12px] text-gray-600 mt-1 leading-relaxed") {{gap.description}}
                                div(class="flex items-center gap-4 mt-2")
                                    div(class="flex items-center gap-1")
                                        span(class="text-[10px] text-gray-400") 조합 밀도:
                                        div(class="w-16 bg-gray-200 rounded-full h-1.5")
                                            div(class="h-1.5 rounded-full", [ngClass]="getDensityColor(gap.combo_density)", [style.width.%]="getDensityBarWidth(gap.combo_density)")
                                        span(class="text-[10px] font-mono text-gray-500") {{(gap.combo_density * 100).toFixed(0)}}%
                                    div(class="flex items-center gap-1")
                                        span(class="text-[10px] text-gray-400") 관련 문서:
                                        span(class="text-[10px] font-mono text-gray-600") {{gap.doc_count}}건
                            div(class="flex-shrink-0 text-right")
                                div(class="text-[11px] text-gray-400 mb-1") Gap 점수
                                div(class="text-[16px] font-bold", [ngClass]="{'text-rose-600': gap.gap_score > 0.1, 'text-amber-600': gap.gap_score > 0.05, 'text-green-600': gap.gap_score <= 0.05}") {{(gap.gap_score * 100).toFixed(1)}}

                        //- Expanded Related Docs
                        div(*ngIf="expandedGap === gi && gap.related_docs && gap.related_docs.length > 0", class="mt-3 ml-13 space-y-2", (click)="$event.stopPropagation()")
                            div(class="text-[11px] text-gray-400 font-medium mb-2") 관련 문서 (가장 가까운 문헌)
                            div(*ngFor="let doc of gap.related_docs", class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-100")
                                div(class="flex items-center gap-2 mb-1")
                                    span(class="inline-flex items-center rounded bg-blue-50 px-1.5 py-0.5 text-[10px] font-medium text-blue-700") {{doc.filename}}
                                    span(class="text-[10px] font-mono", [ngClass]="{'text-green-600': doc.score > 0.5, 'text-amber-600': doc.score <= 0.5}") {{(doc.score * 100).toFixed(1)}}%
                                p(class="text-[12px] text-gray-600 leading-relaxed line-clamp-3") {{doc.snippet}}

                //- No gaps found
                div(*ngIf="gapResults.length === 0", class="px-6 py-12 text-center")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-10 text-green-300 mx-auto mb-3")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z")
                    p(class="text-[13px] text-gray-500") 분석한 키워드 조합에서 뚜렷한 연구 공백이 발견되지 않았습니다.
                    p(class="text-[11px] text-gray-400 mt-1") 다른 키워드 조합으로 시도해 보세요.

            //- Empty state
            div(*ngIf="!gapLoading && !gapAnalyzed", class="px-6 py-16 text-center")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-10 text-gray-300 mx-auto mb-3")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z")
                p(class="text-[13px] text-gray-500") 분석할 키워드를 쉼표로 구분하여 입력하고 'Gap 분석' 버튼을 클릭하세요.
                p(class="text-[11px] text-gray-400 mt-1") 예: 플라즈마, 에칭, 균일도 → 각 키워드 간 교차 영역의 연구 밀도를 비교합니다.

        //- ============================================================
        //- TAB: 가설 생성
        //- ============================================================
        div(*ngIf="activeTab === 'hypothesis'")
            div(class="px-6 py-5 border-b border-gray-100")
                h2(class="text-[15px] font-semibold text-gray-900") 연구 가설 자동 생성
                p(class="mt-1 text-[13px] text-gray-500") 연구 조건을 입력하면 관련 논문을 검색하고, 패턴 분석을 통해 가설 후보를 자동 생성합니다.

                div(class="mt-4")
                    textarea([(ngModel)]="hypothesisCondition", rows="3", placeholder="연구 조건/질문을 입력하세요\n예: 대기압 플라즈마에서 폴리머 표면 처리 시 접착력 향상 조건", class="w-full px-4 py-3 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all resize-none")
                div(class="mt-3 flex items-center justify-between")
                    div(class="flex flex-wrap gap-2")
                        span(class="text-[11px] text-gray-400 leading-6") 예시:
                        button(*ngFor="let sug of hypothesisSuggestions", (click)="hypothesisCondition = sug", class="inline-flex items-center rounded-full bg-indigo-50 border border-indigo-200 px-2.5 py-0.5 text-[11px] font-medium text-indigo-700 hover:bg-indigo-100 transition-colors cursor-pointer") {{sug.length > 30 ? sug.substring(0, 30) + '...' : sug}}
                    button((click)="generateHypothesis()", [disabled]="hypothesisLoading || !hypothesisCondition.trim()", class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-[13px] font-semibold text-white shadow-sm hover:bg-indigo-500 disabled:opacity-50 transition-all active:scale-95 ml-3 flex-shrink-0")
                        svg(class="animate-spin size-4", viewBox="0 0 24 24", *ngIf="hypothesisLoading")
                            circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                            path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                        svg(*ngIf="!hypothesisLoading", xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                            path(stroke-linecap="round", stroke-linejoin="round", d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18")
                        | 가설 생성

            //- Loading
            div(*ngIf="hypothesisLoading", class="px-6 py-16")
                div(class="flex flex-col items-center justify-center gap-3")
                    svg(class="animate-spin size-8 text-indigo-600", viewBox="0 0 24 24")
                        circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                        path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                    p(class="text-[13px] text-gray-500 font-medium") 연구 가설을 생성하고 있습니다...
                    p(class="text-[11px] text-gray-400") 관련 논문 검색 · 패턴 분석 · 가설 후보 생성

            //- Hypothesis Results
            div(*ngIf="!hypothesisLoading && hypothesisGenerated")
                //- Novel Terms
                div(*ngIf="hypothesisNovelTerms.length > 0", class="px-6 py-4 border-b border-gray-100")
                    div(class="text-[13px] font-semibold text-gray-700 mb-2") 관련 문헌에서 발견된 핵심 변수
                    div(class="flex flex-wrap gap-2")
                        div(*ngFor="let nt of hypothesisNovelTerms", class="inline-flex items-center gap-1 rounded-full bg-indigo-50 border border-indigo-200 px-3 py-1")
                            span(class="text-[12px] font-medium text-indigo-700") {{nt.term}}
                            span(class="text-[10px] text-indigo-400") ×{{nt.frequency}}

                //- Hypothesis Cards
                div(*ngIf="hypotheses.length > 0", class="divide-y divide-gray-100")
                    div(*ngFor="let hyp of hypotheses; let hi = index", class="px-6 py-4 hover:bg-gray-50/50 transition-colors cursor-pointer", (click)="toggleHypothesis(hi)")
                        div(class="flex items-start gap-4")
                            div(class="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center", [ngClass]="{'bg-blue-50': hyp.type === 'parameter_optimization', 'bg-purple-50': hyp.type === 'mechanism_study', 'bg-rose-50': hyp.type === 'cross_domain', 'bg-emerald-50': hyp.type === 'novel_application', 'bg-amber-50': hyp.type === 'prediction_model'}")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5", [ngClass]="{'text-blue-600': hyp.type === 'parameter_optimization', 'text-purple-600': hyp.type === 'mechanism_study', 'text-rose-600': hyp.type === 'cross_domain', 'text-emerald-600': hyp.type === 'novel_application', 'text-amber-600': hyp.type === 'prediction_model'}")
                                    path(stroke-linecap="round", stroke-linejoin="round", [attr.d]="getHypothesisIcon(hyp.type)")
                            div(class="flex-1 min-w-0")
                                div(class="flex items-center gap-2 mb-1")
                                    span(class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold", [ngClass]="getHypothesisTypeColor(hyp.type)") {{hyp.type_label}}
                                h3(class="text-[14px] font-semibold text-gray-900") {{hyp.title}}
                                p(class="text-[12px] text-gray-500 mt-1 leading-relaxed") {{hyp.description}}
                            div(class="flex-shrink-0 text-right")
                                div(class="text-[11px] text-gray-400 mb-1") 신뢰도
                                div(class="flex items-center gap-1")
                                    div(class="w-14 bg-gray-200 rounded-full h-1.5")
                                        div(class="bg-indigo-500 h-1.5 rounded-full transition-all", [style.width.%]="hyp.confidence * 100")
                                    span(class="text-[12px] font-mono text-gray-600 w-12 text-right") {{(hyp.confidence * 100).toFixed(1)}}%

                        //- Expanded: Experiment Design + Evidence
                        div(*ngIf="expandedHypothesis === hi", class="mt-3 ml-13 space-y-3", (click)="$event.stopPropagation()")
                            //- Experiment Design
                            div(class="bg-indigo-50 rounded-lg px-4 py-3 border border-indigo-100")
                                div(class="text-[11px] text-indigo-600 font-semibold mb-1 flex items-center gap-1")
                                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-3")
                                        path(stroke-linecap="round", stroke-linejoin="round", d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5")
                                    | 실험 설계 제안
                                p(class="text-[12px] text-indigo-800 leading-relaxed") {{hyp.experiment_design}}

                            //- Evidence
                            div(*ngIf="hyp.evidence && hyp.evidence.length > 0")
                                div(class="text-[11px] text-gray-400 font-medium mb-2 flex items-center gap-1")
                                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-3")
                                        path(stroke-linecap="round", stroke-linejoin="round", d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z")
                                    | 근거 문헌
                                div(*ngFor="let ev of hyp.evidence", class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-100")
                                    div(class="flex items-center gap-2 mb-1")
                                        span(class="inline-flex items-center rounded bg-blue-50 px-1.5 py-0.5 text-[10px] font-medium text-blue-700") {{ev.filename}}
                                        span(class="text-[10px] font-mono", [ngClass]="{'text-green-600': ev.score > 0.5, 'text-amber-600': ev.score <= 0.5}") {{(ev.score * 100).toFixed(1)}}%
                                    p(class="text-[12px] text-gray-600 leading-relaxed line-clamp-3") {{ev.text}}

                //- No hypotheses
                div(*ngIf="hypotheses.length === 0", class="px-6 py-12 text-center")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-10 text-gray-300 mx-auto mb-3")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z")
                    p(class="text-[13px] text-gray-400") 가설을 생성할 수 없습니다. 더 많은 논문을 임베딩하거나 다른 조건으로 시도하세요.

            //- Empty state
            div(*ngIf="!hypothesisLoading && !hypothesisGenerated", class="px-6 py-16 text-center")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-10 text-gray-300 mx-auto mb-3")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18")
                p(class="text-[13px] text-gray-500") 연구 조건/질문을 입력하고 '가설 생성' 버튼을 클릭하세요.
                p(class="text-[11px] text-gray-400 mt-1") 관련 논문에서 패턴을 분석하여 5가지 유형의 가설 후보를 자동 생성합니다.

        //- ============================================================
        //- TAB: 키워드 분석
        //- ============================================================
        div(*ngIf="activeTab === 'keywords'")
            div(class="px-6 py-4 border-b border-gray-100 flex items-center justify-between")
                div(class="flex items-center gap-2")
                    h2(class="text-[15px] font-semibold text-gray-900") 핵심 키워드 분석
                    span(*ngIf="keywordsData.length > 0", class="inline-flex items-center rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-medium text-amber-700") {{keywordsData.length}}개
                button((click)="loadKeywords()", [disabled]="keywordsLoading", class="inline-flex items-center gap-1.5 rounded-lg bg-amber-600 px-4 py-2 text-[12px] font-semibold text-white shadow-sm hover:bg-amber-500 disabled:opacity-50 transition-all active:scale-95")
                    span(*ngIf="!keywordsLoading") 분석 실행
                    span(*ngIf="keywordsLoading") 분석 중...

            div(class="px-6 py-5")
                div(*ngIf="keywordsLoading", class="flex items-center justify-center gap-2 py-8")
                    svg(class="animate-spin size-5 text-amber-600", viewBox="0 0 24 24")
                        circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                        path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
                    span(class="text-[13px] text-gray-500") 키워드 분석 중...

                div(*ngIf="!keywordsLoading && keywordsData.length === 0", class="text-center py-12")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-10 text-gray-300 mx-auto mb-3")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M6 6h.008v.008H6V6Z")
                    p(class="text-[13px] text-gray-400") '분석 실행' 버튼을 클릭하여 저장된 논문의 핵심 키워드를 추출하세요.

                div(*ngIf="!keywordsLoading && keywordsData.length > 0", class="space-y-2")
                    div(*ngFor="let kw of keywordsData; let i = index", class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50 transition-colors group")
                        div(class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-[11px] font-bold", [ngClass]="{'bg-amber-100 text-amber-700': i < 3, 'bg-gray-100 text-gray-500': i >= 3}") {{i + 1}}
                        div(class="flex-1 min-w-0")
                            div(class="flex items-center gap-2")
                                span(class="text-[13px] font-medium text-gray-900") {{kw.term}}
                                span(class="text-[11px] text-gray-400") {{kw.doc_count}}개 문서
                            div(class="mt-1 w-full bg-gray-200 rounded-full h-1.5")
                                div(class="bg-amber-500 h-1.5 rounded-full transition-all", [style.width.%]="(kw.frequency / maxFrequency) * 100")
                        span(class="text-[12px] text-gray-500 font-mono") {{kw.frequency}}회
                        button((click)="searchKeyword = kw.term; switchTab('discover'); searchAndRecommend()", class="opacity-0 group-hover:opacity-100 text-[11px] text-violet-600 hover:text-violet-500 font-medium transition-all") 추천

        //- ========================================
        //- 논문 추천 탭 (recommend)
        //- ========================================
        div(*ngIf="activeTab === 'recommend'")
            div(class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6")
                h2(class="text-[15px] font-semibold text-gray-900 mb-4") 관심 분야 기반 논문 추천
                p(class="text-[13px] text-gray-500 mb-4") 연구 관심 분야를 입력하면, 저장된 컬렉션에서 관련 논문을 추천합니다.
                div(class="space-y-4")
                    textarea(class="w-full px-4 py-3 border border-gray-300 rounded-lg text-[13px] focus:ring-2 focus:ring-amber-200 focus:border-amber-400", rows="3", placeholder="관심 분야를 입력하세요 (예: 플라즈마 에칭 균일도 향상, 저온 CVD 박막 특성...)", [(ngModel)]="recInterests")
                    div(class="flex items-center gap-3")
                        button((click)="getRecommendations()", [disabled]="recLoading || !recInterests.trim()", class="px-6 py-2.5 bg-amber-600 text-white text-[13px] font-medium rounded-lg hover:bg-amber-700 disabled:opacity-50 transition-colors")
                            span(*ngIf="!recLoading") 추천 받기
                            span(*ngIf="recLoading") 분석 중...

            //- 추천 결과
            div(*ngIf="recResults.length > 0", class="space-y-3")
                div(*ngFor="let paper of recResults; let i = index", class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:border-amber-200 transition-colors")
                    div(class="flex items-start gap-3")
                        div(class="flex-shrink-0 w-7 h-7 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-[11px] font-bold") {{i + 1}}
                        div(class="flex-1")
                            h3(class="text-[13px] font-semibold text-gray-900 mb-1") {{paper.title || '제목 없음'}}
                            p(class="text-[12px] text-gray-500 mb-2 line-clamp-3") {{paper.abstract || paper.text || ''}}
                            div(class="flex items-center gap-3")
                                span(*ngIf="paper.score", class="text-[11px] text-amber-600 font-mono") 유사도: {{(paper.score * 100).toFixed(1)}}%
                                span(*ngIf="paper.authors", class="text-[11px] text-gray-400") {{paper.authors}}

        //- ========================================
        //- 제안서 생성 탭 (proposal)
        //- ========================================
        div(*ngIf="activeTab === 'proposal'")
            div(class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6")
                h2(class="text-[15px] font-semibold text-gray-900 mb-4") 연구 제안서 초안 생성
                p(class="text-[13px] text-gray-500 mb-4") 연구 주제와 목표를 입력하면, 저장된 문헌 기반으로 제안서 초안을 생성합니다.
                div(class="space-y-4")
                    div
                        label(class="block text-[12px] font-medium text-gray-600 mb-1") 연구 제목
                        input(type="text", class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-[13px] focus:ring-2 focus:ring-amber-200 focus:border-amber-400", placeholder="연구 제목을 입력하세요", [(ngModel)]="proposalTitle")
                    div
                        label(class="block text-[12px] font-medium text-gray-600 mb-1") 연구 목표
                        textarea(class="w-full px-4 py-3 border border-gray-300 rounded-lg text-[13px] focus:ring-2 focus:ring-amber-200 focus:border-amber-400", rows="3", placeholder="연구의 주요 목표와 기대 성과를 입력하세요", [(ngModel)]="proposalObjective")
                    div
                        label(class="block text-[12px] font-medium text-gray-600 mb-1") 핵심 키워드 (쉼표 구분)
                        input(type="text", class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-[13px] focus:ring-2 focus:ring-amber-200 focus:border-amber-400", placeholder="플라즈마, 에칭, 균일도", [(ngModel)]="proposalKeywords")
                    button((click)="generateProposal()", [disabled]="proposalLoading || !proposalTitle.trim()", class="px-6 py-2.5 bg-amber-600 text-white text-[13px] font-medium rounded-lg hover:bg-amber-700 disabled:opacity-50 transition-colors")
                        span(*ngIf="!proposalLoading") 제안서 생성
                        span(*ngIf="proposalLoading") 생성 중...

            //- 제안서 결과
            div(*ngIf="proposalResult", class="bg-white rounded-xl shadow-sm border border-gray-200 p-6")
                h3(class="text-[15px] font-semibold text-gray-900 mb-4") 생성된 제안서 초안
                div(class="space-y-4")
                    div(*ngIf="proposalResult.background", class="p-4 bg-gray-50 rounded-lg")
                        h4(class="text-[13px] font-semibold text-gray-700 mb-2") 연구 배경
                        p(class="text-[13px] text-gray-600 whitespace-pre-line") {{proposalResult.background}}
                    div(*ngIf="proposalResult.methodology", class="p-4 bg-gray-50 rounded-lg")
                        h4(class="text-[13px] font-semibold text-gray-700 mb-2") 연구 방법론
                        p(class="text-[13px] text-gray-600 whitespace-pre-line") {{proposalResult.methodology}}
                    div(*ngIf="proposalResult.expected_results", class="p-4 bg-gray-50 rounded-lg")
                        h4(class="text-[13px] font-semibold text-gray-700 mb-2") 기대 결과
                        p(class="text-[13px] text-gray-600 whitespace-pre-line") {{proposalResult.expected_results}}
                    div(*ngIf="proposalResult.references && proposalResult.references.length > 0", class="p-4 bg-gray-50 rounded-lg")
                        h4(class="text-[13px] font-semibold text-gray-700 mb-2") 참고 문헌
                        div(*ngFor="let ref of proposalResult.references", class="text-[12px] text-gray-500 mb-1") • {{ref}}

        //- ========================================
        //- 특허 검색 탭 (patent)
        //- ========================================
        div(*ngIf="activeTab === 'patent'")
            div(class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6")
                h2(class="text-[15px] font-semibold text-gray-900 mb-4") 특허 기술 검색
                p(class="text-[13px] text-gray-500 mb-4") 기술 키워드를 입력하면, 저장된 문헌에서 특허 관련 기술 동향을 검색합니다.
                div(class="flex gap-3")
                    input(type="text", class="flex-1 px-4 py-2.5 border border-gray-300 rounded-lg text-[13px] focus:ring-2 focus:ring-amber-200 focus:border-amber-400", placeholder="기술 키워드 (예: atomic layer etching, 플라즈마 표면처리)", [(ngModel)]="patentQuery", (keydown.enter)="searchPatents()")
                    button((click)="searchPatents()", [disabled]="patentSearching || !patentQuery.trim()", class="px-6 py-2.5 bg-amber-600 text-white text-[13px] font-medium rounded-lg hover:bg-amber-700 disabled:opacity-50 transition-colors whitespace-nowrap")
                        span(*ngIf="!patentSearching") 검색
                        span(*ngIf="patentSearching") 검색 중...

            //- 검색 결과
            div(*ngIf="patentResults.length > 0", class="space-y-3")
                div(*ngFor="let patent of patentResults; let i = index", class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:border-amber-200 transition-colors")
                    div(class="flex items-start gap-3")
                        div(class="flex-shrink-0 w-7 h-7 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-[11px] font-bold") {{i + 1}}
                        div(class="flex-1")
                            h3(class="text-[13px] font-semibold text-gray-900 mb-1") {{patent.title || '제목 없음'}}
                            p(class="text-[12px] text-gray-500 mb-2 line-clamp-3") {{patent.abstract || patent.text || ''}}
                            div(class="flex items-center gap-3")
                                span(*ngIf="patent.score", class="text-[11px] text-amber-600 font-mono") 관련도: {{(patent.score * 100).toFixed(1)}}%
                                span(*ngIf="patent.year", class="text-[11px] text-gray-400") {{patent.year}}

