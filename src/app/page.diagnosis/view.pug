nav(class="sticky top-0 z-20 bg-white shadow")
    div(class="max-w-6xl px-4 sm:px-6 lg:px-8 py-3")
        div(class="flex items-center justify-between")
            h1(class="flex text-lg font-semibold text-zinc-950 gap-x-3 items-center")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-6 text-rose-600")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5")
                span 진단 데이터 분석
            div(*ngIf="collections.length > 0", class="flex items-center gap-2")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4 text-gray-400")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125")
                select([(ngModel)]="selectedCollection", (ngModelChange)="onCollectionChange()", class="px-3 py-1.5 rounded-lg border border-gray-300 text-[12px] bg-white focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none")
                    option(*ngFor="let col of collections", [value]="col.name") {{col.name}} ({{col.short_name}})

div(class="max-w-6xl pt-4 px-4 sm:px-6 lg:px-8 pb-8 space-y-5")

    //- Stats Cards
    div(class="grid grid-cols-2 md:grid-cols-4 gap-3")
        div(class="bg-white rounded-xl border border-gray-200 px-4 py-3 shadow-sm")
            div(class="text-[11px] text-gray-400 font-medium") 총 청크
            div(class="text-xl font-bold text-gray-900 mt-0.5") {{overviewStats.total_chunks || 0}}
        div(class="bg-white rounded-xl border border-gray-200 px-4 py-3 shadow-sm")
            div(class="text-[11px] text-gray-400 font-medium") 스펙트럼 DB
            div(class="text-xl font-bold text-indigo-600 mt-0.5") {{overviewStats.spectrum_count || 0}}
        div(class="bg-white rounded-xl border border-gray-200 px-4 py-3 shadow-sm")
            div(class="text-[11px] text-gray-400 font-medium") Baseline
            div(class="text-xl font-bold mt-0.5", [ngClass]="overviewStats.has_baseline ? 'text-green-600' : 'text-gray-300'") {{overviewStats.has_baseline ? '설정됨' : '미설정'}}
        div(class="bg-white rounded-xl border border-gray-200 px-4 py-3 shadow-sm")
            div(class="text-[11px] text-gray-400 font-medium") 이상 탐지 이력
            div(class="text-xl font-bold text-rose-600 mt-0.5") {{overviewStats.anomaly_count || 0}}

    //- Tab Navigation
    div(class="bg-white rounded-xl border border-gray-200 shadow-sm")
        div(class="border-b border-gray-200 overflow-x-auto")
            nav(class="flex -mb-px px-4 min-w-max")
                button(*ngFor="let tab of tabs", (click)="switchTab(tab.id)", class="px-4 py-3 text-[13px] font-medium border-b-2 transition-colors whitespace-nowrap", [ngClass]="activeTab === tab.id ? 'border-rose-500 text-rose-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'") {{tab.label}}

        //- ===================== Tab: 문헌 검색 =====================
        div(*ngIf="activeTab === 'search'", class="px-6 py-5")
            div(class="space-y-4")
                div
                    label(class="block text-[12px] font-medium text-gray-700 mb-1.5") 진단 방법 (선택)
                    div(class="flex flex-wrap gap-2")
                        button(*ngFor="let dt of diagnosticTypes", (click)="selectedDiagType = selectedDiagType === dt ? '' : dt", class="inline-flex items-center rounded-full px-3 py-1 text-[12px] font-medium transition-colors border", [ngClass]="selectedDiagType === dt ? 'bg-rose-100 border-rose-300 text-rose-700' : 'bg-white border-gray-200 text-gray-600 hover:border-rose-200 hover:text-rose-600'") {{dt}}
                div(class="flex gap-3")
                    div(class="flex-1 relative")
                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400")
                            path(stroke-linecap="round", stroke-linejoin="round", d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z")
                        input(type="text", [(ngModel)]="searchQuery", placeholder="예: 전자 온도 측정, OES 스펙트럼 분석...", class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none", (keyup.enter)="searchDiagnostic()")
                    button((click)="searchDiagnostic()", [disabled]="searching", class="inline-flex items-center gap-2 rounded-lg bg-rose-600 px-5 py-2.5 text-[13px] font-semibold text-white shadow-sm hover:bg-rose-500 disabled:opacity-50 transition-all active:scale-95")
                        span(*ngIf="searching") 검색 중...
                        span(*ngIf="!searching") 검색
            div(*ngIf="searchResults.length > 0", class="mt-5")
                p(class="text-[13px] font-medium text-gray-700 mb-3") 검색 결과 ({{searchResults.length}}건) — "{{lastSearchQuery}}"
                div(class="space-y-2")
                    div(*ngFor="let r of searchResults; let i = index", class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-100 hover:border-rose-200 transition-colors")
                        div(class="flex items-center justify-between mb-1.5")
                            div(class="flex items-center gap-2")
                                span(class="text-[11px] font-bold text-gray-400") {{'#'}}{{i + 1}}
                                span(class="text-[12px] font-medium text-gray-900") {{r.filename}}
                                span(class="text-[10px] text-gray-400 font-mono") chunk {{'#'}}{{r.chunk_index}}
                            div(class="flex items-center gap-1")
                                div(class="w-14 bg-gray-200 rounded-full h-1.5")
                                    div(class="bg-rose-500 h-1.5 rounded-full", [style.width.%]="r.score * 100")
                                span(class="text-[11px] font-mono text-rose-600") {{(r.score * 100).toFixed(1)}}%
                        p(class="text-[12px] text-gray-600 leading-relaxed line-clamp-3") {{r.text}}

        //- ===================== Tab: 스펙트럼 분석 =====================
        div(*ngIf="activeTab === 'spectrum'", class="px-6 py-5 space-y-5")
            //- Upload section
            div(class="bg-indigo-50 border border-indigo-100 rounded-lg p-4")
                h3(class="text-[13px] font-semibold text-indigo-800 mb-3") OES 스펙트럼 업로드
                div(class="grid grid-cols-1 md:grid-cols-3 gap-3")
                    div(class="md:col-span-2")
                        label(class="block text-[12px] font-medium text-gray-700 mb-1") 스펙트럼 파일 (CSV: wavelength,intensity)
                        input(type="file", accept=".csv,.txt,.tsv", (change)="handleSpectrumFile($event)", class="block w-full text-[12px] text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-[12px] file:font-medium file:bg-indigo-100 file:text-indigo-700 hover:file:bg-indigo-200")
                    div
                        label(class="block text-[12px] font-medium text-gray-700 mb-1") 라벨
                        input(type="text", [(ngModel)]="spectrumLabel", placeholder="예: Ar/O2 500W", class="w-full px-3 py-1.5 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-indigo-500 outline-none")
                div(*ngIf="spectrumInput", class="mt-3 flex gap-2")
                    button((click)="uploadSpectrum()", [disabled]="uploading", class="rounded-lg bg-indigo-600 px-4 py-2 text-[12px] font-semibold text-white hover:bg-indigo-500 disabled:opacity-50")
                        | {{uploading ? '저장 중...' : 'DB에 저장'}}
                    button((click)="searchSimilarSpectrum()", [disabled]="searchingSpectrum", class="rounded-lg bg-white border border-indigo-300 px-4 py-2 text-[12px] font-semibold text-indigo-700 hover:bg-indigo-50 disabled:opacity-50")
                        | {{searchingSpectrum ? '검색 중...' : '유사 스펙트럼 검색'}}

            //- Upload result
            div(*ngIf="spectrumResult", class="bg-white border border-green-200 rounded-lg p-4")
                h4(class="text-[13px] font-semibold text-green-700 mb-2") ✓ 업로드 완료 — {{spectrumResult.label}}
                div(class="flex flex-wrap gap-3 text-[12px] text-gray-600")
                    span 데이터 포인트: {{spectrumResult.n_points}}
                    span 파장 범위: {{spectrumResult.wl_range?.[0]?.toFixed(0)}}–{{spectrumResult.wl_range?.[1]?.toFixed(0)}} nm
                    span 피크 수: {{spectrumResult.peaks?.length || 0}}
                div(*ngIf="spectrumResult.species_list?.length > 0", class="mt-2 flex flex-wrap gap-1.5")
                    span(*ngFor="let sp of spectrumResult.species_list", class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-[11px] font-medium text-indigo-700") {{sp}}

            //- Similar spectrum search results
            div(*ngIf="spectrumQueryInfo", class="space-y-4")
                div(class="bg-white border border-gray-200 rounded-lg p-4")
                    h4(class="text-[13px] font-semibold text-gray-900 mb-2") 분석 결과
                    div(class="flex flex-wrap gap-3 text-[12px] text-gray-600 mb-2")
                        span 피크 {{spectrumQueryInfo.n_peaks}}개 검출
                        span 파장 범위: {{spectrumQueryInfo.wl_range?.[0]?.toFixed(0)}}–{{spectrumQueryInfo.wl_range?.[1]?.toFixed(0)}} nm
                    //- Identified species
                    div(*ngIf="spectrumQueryInfo.species_list?.length > 0")
                        p(class="text-[12px] font-medium text-gray-700 mb-1.5") 검출된 화학종
                        div(class="flex flex-wrap gap-1.5")
                            span(*ngFor="let sp of spectrumQueryInfo.species_list", class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-[11px] font-medium text-indigo-700") {{sp}}
                    //- Peak details
                    div(*ngIf="spectrumQueryInfo.identified_species?.length > 0", class="mt-3")
                        p(class="text-[12px] font-medium text-gray-700 mb-1.5") 발광선 매칭
                        div(class="grid grid-cols-2 md:grid-cols-3 gap-2")
                            div(*ngFor="let s of spectrumQueryInfo.identified_species.slice(0, 12)", class="bg-gray-50 rounded px-2.5 py-1.5 text-[11px] border border-gray-100")
                                span(class="font-semibold text-indigo-600") {{s.species}}
                                span(class="text-gray-500 ml-1") {{s.measured}} nm
                                span(class="text-gray-400 ml-1") (±{{s.offset_nm}} nm)

                //- Similar spectra
                div(*ngIf="similarSpectra.length > 0", class="bg-white border border-gray-200 rounded-lg p-4")
                    h4(class="text-[13px] font-semibold text-gray-900 mb-3") 유사 스펙트럼 ({{similarSpectra.length}}건)
                    div(class="space-y-2")
                        div(*ngFor="let s of similarSpectra; let i = index", class="flex items-center justify-between bg-gray-50 rounded-lg px-3 py-2 border border-gray-100")
                            div(class="flex items-center gap-3")
                                span(class="text-[11px] font-bold text-gray-400 w-5") {{'#'}}{{i+1}}
                                div
                                    span(class="text-[12px] font-medium text-gray-900") {{s.label}}
                                    div(class="flex flex-wrap gap-1 mt-0.5")
                                        span(*ngFor="let sp of s.species_list?.slice(0, 5)", class="text-[10px] bg-indigo-50 text-indigo-600 rounded px-1.5 py-0.5") {{sp}}
                            div(class="flex items-center gap-2")
                                div(class="w-16 bg-gray-200 rounded-full h-1.5")
                                    div(class="bg-indigo-500 h-1.5 rounded-full", [style.width.%]="s.similarity * 100")
                                span(class="text-[11px] font-mono text-indigo-600 w-12 text-right") {{(s.similarity * 100).toFixed(1)}}%

                //- Related papers
                div(*ngIf="relatedPapers.length > 0", class="bg-white border border-gray-200 rounded-lg p-4")
                    h4(class="text-[13px] font-semibold text-gray-900 mb-3") 관련 논문 ({{relatedPapers.length}}건)
                    div(class="space-y-2")
                        div(*ngFor="let r of relatedPapers; let i = index", class="bg-gray-50 rounded-lg px-3 py-2.5 border border-gray-100")
                            div(class="flex items-center justify-between mb-1")
                                span(class="text-[12px] font-medium text-gray-900") {{r.filename}}
                                span(class="text-[11px] font-mono text-rose-600") {{(r.score * 100).toFixed(1)}}%
                            p(class="text-[11px] text-gray-600 line-clamp-2") {{r.text}}

            //- Stored spectra list
            div(*ngIf="storedSpectra.length > 0", class="bg-white border border-gray-200 rounded-lg p-4")
                h4(class="text-[13px] font-semibold text-gray-900 mb-3") 저장된 스펙트럼 ({{storedSpectra.length}}건)
                div(class="space-y-2")
                    div(*ngFor="let s of storedSpectra", class="flex items-center justify-between bg-gray-50 rounded px-3 py-2 border border-gray-100")
                        div
                            span(class="text-[12px] font-medium text-gray-900") {{s.label}}
                            span(class="text-[10px] text-gray-400 ml-2") {{s.timestamp}}
                            div(class="flex flex-wrap gap-1 mt-0.5")
                                span(*ngFor="let sp of s.species_list?.slice(0, 6)", class="text-[10px] bg-gray-100 text-gray-600 rounded px-1.5 py-0.5") {{sp}}
                        button((click)="deleteSpectrum(s.id)", class="text-[11px] text-red-500 hover:text-red-700") 삭제

        //- ===================== Tab: 멀티모달 검색 =====================
        div(*ngIf="activeTab === 'multimodal'", class="px-6 py-5 space-y-4")
            div(class="bg-purple-50 border border-purple-100 rounded-lg p-4")
                p(class="text-[13px] text-purple-700") 텍스트와 스펙트럼을 결합한 하이브리드 검색입니다. 검출된 화학종 정보로 논문을 추가 검색하여 결과를 융합합니다.
            //- Text input
            div
                label(class="block text-[12px] font-medium text-gray-700 mb-1") 텍스트 검색어
                input(type="text", [(ngModel)]="mmTextQuery", placeholder="예: Ar/O2 ICP plasma electron density measurement", class="w-full px-3 py-2.5 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-purple-500 outline-none", (keyup.enter)="multimodalSearch()")
            //- Spectrum input
            div
                label(class="block text-[12px] font-medium text-gray-700 mb-1") 스펙트럼 파일 (선택)
                input(type="file", accept=".csv,.txt,.tsv", (change)="handleMmSpectrumFile($event)", class="block w-full text-[12px] text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-[12px] file:font-medium file:bg-purple-100 file:text-purple-700 hover:file:bg-purple-200")
            //- Weight sliders
            div(class="grid grid-cols-2 gap-4")
                div
                    label(class="block text-[12px] font-medium text-gray-700 mb-1") 텍스트 가중치: {{mmTextWeight.toFixed(1)}}
                    input(type="range", [(ngModel)]="mmTextWeight", min="0", max="1", step="0.1", class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600")
                div
                    label(class="block text-[12px] font-medium text-gray-700 mb-1") 스펙트럼 가중치: {{mmSpectrumWeight.toFixed(1)}}
                    input(type="range", [(ngModel)]="mmSpectrumWeight", min="0", max="1", step="0.1", class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600")
            button((click)="multimodalSearch()", [disabled]="mmSearching || (!mmTextQuery.trim() && !mmSpectrumData.trim())", class="rounded-lg bg-purple-600 px-5 py-2.5 text-[13px] font-semibold text-white hover:bg-purple-500 disabled:opacity-50 transition-all")
                | {{mmSearching ? '검색 중...' : '멀티모달 검색'}}

            //- Spectrum info
            div(*ngIf="mmSpectrumInfo", class="bg-white border border-purple-200 rounded-lg p-3")
                span(class="text-[12px] font-medium text-purple-700") 스펙트럼 분석:
                span(class="text-[12px] text-gray-600 ml-1") 피크 {{mmSpectrumInfo.n_peaks}}개,
                span(*ngFor="let sp of mmSpectrumInfo.species_list", class="inline-flex items-center rounded-full bg-purple-100 px-2 py-0.5 text-[10px] font-medium text-purple-700 ml-1") {{sp}}

            //- Results
            div(*ngIf="mmResults.length > 0", class="space-y-2")
                p(class="text-[13px] font-medium text-gray-700") 검색 결과 ({{mmResults.length}}건)
                div(*ngFor="let r of mmResults; let i = index", class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-100")
                    div(class="flex items-center justify-between mb-1.5")
                        div(class="flex items-center gap-2")
                            span(class="text-[11px] font-bold text-gray-400") {{'#'}}{{i + 1}}
                            span(class="text-[12px] font-medium text-gray-900") {{r.filename}}
                        div(class="flex items-center gap-3")
                            span(class="text-[10px] text-blue-500") T:{{(r.text_score * 100).toFixed(0)}}%
                            span(class="text-[10px] text-indigo-500") S:{{(r.spectrum_score * 100).toFixed(0)}}%
                            span(class="text-[11px] font-mono font-semibold text-purple-600") {{(r.combined_score * 100).toFixed(1)}}%
                    p(class="text-[12px] text-gray-600 line-clamp-2") {{r.text_snippet}}

        //- ===================== Tab: 이상 탐지 =====================
        div(*ngIf="activeTab === 'detection'", class="px-6 py-5 space-y-5")
            //- Baseline Setup
            div(class="bg-emerald-50 border border-emerald-100 rounded-lg p-4")
                h3(class="text-[13px] font-semibold text-emerald-800 mb-3") Baseline 설정
                div(*ngIf="baselineInfo", class="mb-3 bg-white rounded-lg p-3 border border-emerald-200")
                    div(class="grid grid-cols-2 md:grid-cols-4 gap-3 text-[12px]")
                        div
                            span(class="text-gray-500") 라벨:
                            span(class="font-medium text-gray-900 ml-1") {{baselineInfo.label}}
                        div
                            span(class="text-gray-500") 샘플 수:
                            span(class="font-medium text-gray-900 ml-1") {{baselineInfo.n_samples}}
                        div
                            span(class="text-gray-500") 임계값:
                            span(class="font-medium text-gray-900 ml-1") {{baselineInfo.threshold?.toFixed(4)}}
                        div
                            span(class="text-gray-500") 평균 거리:
                            span(class="font-medium text-gray-900 ml-1") {{baselineInfo.mean_distance?.toFixed(4)}}
                    div(*ngIf="baselineInfo.species_distribution", class="mt-2 flex flex-wrap gap-1")
                        span(*ngFor="let sp of objectKeys(baselineInfo.species_distribution)", class="text-[10px] bg-emerald-100 text-emerald-700 rounded-full px-2 py-0.5") {{sp}} ({{baselineInfo.species_distribution[sp]}})
                div(*ngIf="!baselineInfo", class="space-y-3")
                    div
                        label(class="block text-[12px] font-medium text-gray-700 mb-1") 정상 스펙트럼 CSV (여러 스펙트럼은 '---'로 구분)
                        input(type="file", accept=".csv,.txt", (change)="handleBaselineFile($event)", class="block w-full text-[12px] text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-[12px] file:font-medium file:bg-emerald-100 file:text-emerald-700")
                    div(class="grid grid-cols-2 gap-3")
                        div
                            label(class="block text-[12px] font-medium text-gray-700 mb-1") 라벨
                            input(type="text", [(ngModel)]="baselineLabel", class="w-full px-3 py-1.5 rounded-lg border border-gray-300 text-[13px] outline-none")
                        div
                            label(class="block text-[12px] font-medium text-gray-700 mb-1") 임계값
                            input(type="number", [(ngModel)]="baselineThreshold", step="0.01", min="0.01", max="1", class="w-full px-3 py-1.5 rounded-lg border border-gray-300 text-[13px] outline-none")
                    button(*ngIf="baselineInput", (click)="setBaseline()", [disabled]="settingBaseline", class="rounded-lg bg-emerald-600 px-4 py-2 text-[12px] font-semibold text-white hover:bg-emerald-500 disabled:opacity-50")
                        | {{settingBaseline ? '설정 중...' : 'Baseline 설정'}}

            //- Threshold adjustment
            div(*ngIf="baselineInfo", class="bg-white border border-gray-200 rounded-lg p-4")
                h4(class="text-[13px] font-semibold text-gray-900 mb-2") 감도 조절
                div(class="flex items-center gap-4")
                    span(class="text-[12px] text-green-600") 민감
                    input(type="range", [(ngModel)]="baselineThreshold", min="0.01", max="0.5", step="0.01", class="flex-1 h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-emerald-600")
                    span(class="text-[12px] text-gray-400") 둔감
                    span(class="text-[12px] font-mono text-gray-700 w-12 text-right") {{baselineThreshold.toFixed(2)}}
                    button((click)="updateThreshold()", class="rounded-lg bg-gray-100 px-3 py-1 text-[11px] font-medium text-gray-700 hover:bg-gray-200") 적용

            //- Anomaly Check
            div(*ngIf="baselineInfo", class="bg-white border border-gray-200 rounded-lg p-4")
                h4(class="text-[13px] font-semibold text-gray-900 mb-3") 스펙트럼 이상 검사
                div(class="flex gap-3")
                    div(class="flex-1")
                        input(type="file", accept=".csv,.txt", (change)="handleDetectionFile($event)", class="block w-full text-[12px] text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-[12px] file:font-medium file:bg-rose-100 file:text-rose-700")
                    button(*ngIf="detectionInput", (click)="checkAnomaly()", [disabled]="checking", class="rounded-lg bg-rose-600 px-5 py-2 text-[12px] font-semibold text-white hover:bg-rose-500 disabled:opacity-50")
                        | {{checking ? '검사 중...' : '이상 검사'}}

            //- Detection Result
            div(*ngIf="detectionResult", class="border rounded-lg p-5", [ngClass]="detectionResult.is_anomaly ? 'bg-red-50 border-red-200' : 'bg-green-50 border-green-200'")
                div(class="flex items-center gap-3 mb-3")
                    div(class="w-12 h-12 rounded-full flex items-center justify-center text-white text-lg font-bold", [ngClass]="detectionResult.is_anomaly ? 'bg-red-500' : 'bg-green-500'")
                        span(*ngIf="detectionResult.is_anomaly") ⚠
                        span(*ngIf="!detectionResult.is_anomaly") ✓
                    div
                        div(class="text-[15px] font-bold", [ngClass]="detectionResult.is_anomaly ? 'text-red-700' : 'text-green-700'") {{detectionResult.is_anomaly ? '이상 감지' : '정상'}}
                        div(class="text-[12px] text-gray-600") 거리: {{detectionResult.distance?.toFixed(4)}} / 임계값: {{detectionResult.threshold?.toFixed(4)}}
                //- Severity bar
                div(class="mb-3")
                    div(class="flex justify-between text-[11px] text-gray-500 mb-1")
                        span 정상
                        span 위험
                    div(class="w-full bg-gray-200 rounded-full h-3")
                        div(class="h-3 rounded-full transition-all", [ngClass]="severityBg(detectionResult.severity)", [style.width.%]="detectionResult.severity * 100")
                    div(class="text-center text-[12px] font-semibold mt-1", [ngClass]="severityColor(detectionResult.severity)") {{severityLabel(detectionResult.severity)}} ({{(detectionResult.severity * 100).toFixed(0)}}%)
                div(*ngIf="detectionResult.species_list?.length > 0", class="flex flex-wrap gap-1.5")
                    span(class="text-[11px] text-gray-500") 검출 종:
                    span(*ngFor="let sp of detectionResult.species_list", class="text-[10px] bg-white rounded-full px-2 py-0.5 border") {{sp}}

            //- History
            div(*ngIf="anomalyHistory.length > 0", class="bg-white border border-gray-200 rounded-lg p-4")
                div(class="flex items-center justify-between mb-3")
                    h4(class="text-[13px] font-semibold text-gray-900") 탐지 이력 ({{historyStats?.total || anomalyHistory.length}}건, 이상 {{historyStats?.anomaly_count || 0}}건)
                    button((click)="clearHistory()", class="text-[11px] text-red-500 hover:text-red-700") 이력 초기화
                div(class="space-y-1.5 max-h-64 overflow-y-auto")
                    div(*ngFor="let h of anomalyHistory.slice(0, 30)", class="flex items-center justify-between bg-gray-50 rounded px-3 py-1.5 text-[11px] border border-gray-100")
                        div(class="flex items-center gap-2")
                            span(class="w-2 h-2 rounded-full", [ngClass]="h.is_anomaly ? 'bg-red-500' : 'bg-green-500'")
                            span(class="text-gray-500") {{h.timestamp}}
                        div(class="flex items-center gap-2")
                            span(class="font-mono text-gray-600") d={{h.distance?.toFixed(4)}}
                            span(class="font-medium", [ngClass]="h.is_anomaly ? 'text-red-600' : 'text-green-600'") {{h.is_anomaly ? '이상' : '정상'}}

        //- ===================== Tab: 고장 진단 =====================
        div(*ngIf="activeTab === 'failure'", class="px-6 py-5 space-y-5")
            div(class="bg-amber-50 border border-amber-100 rounded-lg px-4 py-3")
                p(class="text-[13px] text-amber-700") 증상을 입력하면 알려진 고장 패턴 매칭 + 논문 기반 원인 분석 + 해결 방법을 제안합니다. 스펙트럼 데이터도 함께 제공하면 검출된 화학종을 추가 분석합니다.

            //- Input
            div(class="space-y-3")
                div(class="flex gap-3")
                    input(type="text", [(ngModel)]="failureSymptom", placeholder="예: 아크 발생 + CF4 emission peak 증가", class="flex-1 px-3 py-2.5 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-amber-500 outline-none", (keyup.enter)="failureReasoning()")
                    button((click)="failureReasoning()", [disabled]="failureSearching", class="rounded-lg bg-amber-600 px-5 py-2.5 text-[13px] font-semibold text-white hover:bg-amber-500 disabled:opacity-50")
                        | {{failureSearching ? '분석 중...' : '고장 분석'}}
                div(class="flex flex-wrap gap-2")
                    span(class="text-[11px] text-gray-400 leading-6") 빈도 높은 증상:
                    button(*ngFor="let s of commonSymptoms", (click)="failureSymptom = s; failureReasoning()", class="inline-flex items-center rounded-full bg-gray-50 border border-gray-200 px-2.5 py-0.5 text-[11px] text-gray-600 hover:bg-amber-50 hover:border-amber-200 hover:text-amber-600 transition-colors cursor-pointer") {{s}}
                div
                    label(class="block text-[12px] font-medium text-gray-700 mb-1") 스펙트럼 데이터 (선택)
                    input(type="file", accept=".csv,.txt", (change)="handleFailureSpectrumFile($event)", class="block w-full text-[12px] text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-[12px] file:font-medium file:bg-amber-100 file:text-amber-700")

            //- Failure Result
            div(*ngIf="failureResult", class="space-y-4")
                //- Summary
                div(class="bg-white border border-gray-200 rounded-lg p-4")
                    h4(class="text-[13px] font-semibold text-gray-900 mb-2") 분석 요약 — "{{failureResult.summary?.symptom}}"
                    div(class="grid grid-cols-2 md:grid-cols-4 gap-3 text-[12px]")
                        div(class="bg-amber-50 rounded-lg px-3 py-2 text-center")
                            div(class="text-lg font-bold text-amber-700") {{failureResult.summary?.n_matched_patterns || 0}}
                            div(class="text-[10px] text-gray-500") 패턴 매칭
                        div(class="bg-blue-50 rounded-lg px-3 py-2 text-center")
                            div(class="text-lg font-bold text-blue-700") {{failureResult.summary?.n_evidence_docs || 0}}
                            div(class="text-[10px] text-gray-500") 근거 문서
                        div(class="bg-red-50 rounded-lg px-3 py-2 text-center")
                            div(class="text-lg font-bold text-red-700") {{failureResult.summary?.n_cause_docs || 0}}
                            div(class="text-[10px] text-gray-500") 원인 분석
                        div(class="bg-green-50 rounded-lg px-3 py-2 text-center")
                            div(class="text-lg font-bold text-green-700") {{failureResult.summary?.n_solution_docs || 0}}
                            div(class="text-[10px] text-gray-500") 해결 방법

                //- Matched patterns
                div(*ngIf="failureResult.matched_patterns?.length > 0", class="bg-white border border-amber-200 rounded-lg p-4")
                    h4(class="text-[13px] font-semibold text-amber-800 mb-3") 매칭된 고장 패턴
                    div(*ngFor="let pat of failureResult.matched_patterns", class="bg-amber-50/50 rounded-lg p-3 border border-amber-100 mb-2")
                        div(class="flex items-center justify-between mb-2")
                            span(class="text-[13px] font-semibold text-gray-900") {{pat.name}}
                            span(class="text-[11px] font-mono text-amber-600") 매칭 {{(pat.match_score * 100).toFixed(0)}}%
                        div(*ngIf="pat.causes?.length > 0", class="mb-1")
                            span(class="text-[11px] font-medium text-red-600") 원인:
                            span(*ngFor="let c of pat.causes", class="text-[11px] text-gray-600 ml-1") {{c}},
                        div(*ngIf="pat.solutions?.length > 0")
                            span(class="text-[11px] font-medium text-green-600") 해결:
                            span(*ngFor="let s of pat.solutions", class="text-[11px] text-gray-600 ml-1") {{s}},

                //- Spectrum info
                div(*ngIf="failureResult.spectrum_info", class="bg-white border border-indigo-200 rounded-lg p-4")
                    h4(class="text-[13px] font-semibold text-indigo-800 mb-2") 스펙트럼 분석
                    div(class="flex flex-wrap gap-1.5")
                        span(class="text-[12px] text-gray-600") 피크 {{failureResult.spectrum_info.n_peaks}}개 검출 —
                        span(*ngFor="let sp of failureResult.spectrum_info.species_list", class="inline-flex items-center rounded-full bg-indigo-100 px-2 py-0.5 text-[10px] font-medium text-indigo-700") {{sp}}

                //- Evidence docs
                div(*ngIf="failureResult.evidence_docs?.length > 0", class="bg-white border border-gray-200 rounded-lg p-4")
                    h4(class="text-[13px] font-semibold text-gray-900 mb-3") 근거 문서 ({{failureResult.evidence_docs.length}}건)
                    div(class="space-y-2")
                        div(*ngFor="let d of failureResult.evidence_docs; let i = index", class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-100")
                            div(class="flex items-center justify-between mb-1.5")
                                div(class="flex items-center gap-2")
                                    span(class="text-[11px] font-bold text-gray-400") {{'#'}}{{i + 1}}
                                    span(class="text-[12px] font-medium text-gray-900") {{d.filename}}
                                div(class="flex items-center gap-2")
                                    span(*ngFor="let tag of d.tags", class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium", [ngClass]="{'bg-red-50 text-red-700 border border-red-200': tag === '원인분석', 'bg-green-50 text-green-700 border border-green-200': tag === '해결방법', 'bg-gray-100 text-gray-600': tag === '관련자료'}") {{tag}}
                                    span(class="text-[11px] font-mono text-rose-600") {{(d.score * 100).toFixed(1)}}%
                            p(class="text-[12px] text-gray-600 leading-relaxed line-clamp-3") {{d.text}}

            //- Failure Patterns Management
            div(class="bg-white border border-gray-200 rounded-lg p-4")
                div(class="flex items-center justify-between mb-3")
                    h4(class="text-[13px] font-semibold text-gray-900") 등록된 고장 패턴 ({{failurePatterns.length}}건)
                    button((click)="showPatternForm = !showPatternForm", class="text-[12px] text-amber-600 hover:text-amber-500 font-medium")
                        | {{showPatternForm ? '취소' : '+ 패턴 등록'}}
                //- Registration form
                div(*ngIf="showPatternForm", class="bg-gray-50 rounded-lg p-4 mb-3 border border-gray-200 space-y-3")
                    div
                        label(class="block text-[12px] font-medium text-gray-700 mb-1") 패턴 이름 *
                        input(type="text", [(ngModel)]="newPatternName", placeholder="예: RF 아킹 고장", class="w-full px-3 py-1.5 rounded-lg border border-gray-300 text-[13px] outline-none")
                    div
                        label(class="block text-[12px] font-medium text-gray-700 mb-1") 증상 (쉼표 구분) *
                        input(type="text", [(ngModel)]="newPatternSymptoms", placeholder="예: 아킹,전력 반사 증가,스파크", class="w-full px-3 py-1.5 rounded-lg border border-gray-300 text-[13px] outline-none")
                    div
                        label(class="block text-[12px] font-medium text-gray-700 mb-1") 원인 (쉼표 구분)
                        input(type="text", [(ngModel)]="newPatternCauses", placeholder="예: 챔버 오염,절연 파괴,높은 RF power", class="w-full px-3 py-1.5 rounded-lg border border-gray-300 text-[13px] outline-none")
                    div
                        label(class="block text-[12px] font-medium text-gray-700 mb-1") 해결 방법 (쉼표 구분)
                        input(type="text", [(ngModel)]="newPatternSolutions", placeholder="예: 챔버 클리닝,RF power 감소,매칭 재조정", class="w-full px-3 py-1.5 rounded-lg border border-gray-300 text-[13px] outline-none")
                    button((click)="registerPattern()", class="rounded-lg bg-amber-600 px-4 py-1.5 text-[12px] font-semibold text-white hover:bg-amber-500") 등록
                //- Pattern list
                div(*ngIf="failurePatterns.length > 0", class="space-y-2")
                    div(*ngFor="let p of failurePatterns", class="bg-gray-50 rounded-lg px-3 py-2.5 border border-gray-100")
                        div(class="flex items-center justify-between mb-1")
                            span(class="text-[12px] font-semibold text-gray-900") {{p.name}}
                            button((click)="deletePattern(p.id)", class="text-[11px] text-red-500 hover:text-red-700") 삭제
                        div(class="flex flex-wrap gap-1")
                            span(*ngFor="let s of p.symptoms", class="text-[10px] bg-amber-100 text-amber-700 rounded-full px-2 py-0.5") {{s}}
                            span(*ngFor="let c of p.causes", class="text-[10px] bg-red-50 text-red-600 rounded-full px-2 py-0.5") {{c}}
                            span(*ngFor="let s of p.solutions", class="text-[10px] bg-green-50 text-green-600 rounded-full px-2 py-0.5") {{s}}
                div(*ngIf="failurePatterns.length === 0 && !showPatternForm", class="text-center py-4")
                    p(class="text-[13px] text-gray-400") 등록된 패턴이 없습니다. 자주 발생하는 고장 패턴을 등록하면 빠른 진단이 가능합니다.

        //- ===================== Tab: 진단 비교 =====================
        div(*ngIf="activeTab === 'compare'", class="px-6 py-5")
            div(class="space-y-4")
                p(class="text-[13px] text-gray-500") 두 가지 진단 방법을 선택하면 관련 문헌을 비교 분석합니다.
                div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
                    div
                        label(class="block text-[12px] font-medium text-gray-700 mb-1.5") 진단 방법 A
                        input(type="text", [(ngModel)]="compareMethodA", placeholder="예: OES, Langmuir probe...", class="w-full px-3 py-2 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-rose-500 outline-none")
                    div
                        label(class="block text-[12px] font-medium text-gray-700 mb-1.5") 진단 방법 B
                        input(type="text", [(ngModel)]="compareMethodB", placeholder="예: mass spectrometry, SEM...", class="w-full px-3 py-2 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-rose-500 outline-none")
                button((click)="compareDiagnostics()", [disabled]="comparing || !compareMethodA.trim() || !compareMethodB.trim()", class="rounded-lg bg-rose-600 px-5 py-2.5 text-[13px] font-semibold text-white hover:bg-rose-500 disabled:opacity-50")
                    | {{comparing ? '비교 중...' : '비교 분석'}}
            div(*ngIf="comparisonResult", class="mt-6 space-y-4")
                div(class="flex items-center justify-center gap-4 py-3")
                    span(class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-[12px] font-medium text-blue-700") {{comparisonResult.method_a}}
                    span(class="text-[12px] text-gray-400") vs
                    span(class="inline-flex items-center rounded-full bg-purple-100 px-3 py-1 text-[12px] font-medium text-purple-700") {{comparisonResult.method_b}}
                    span(class="text-[11px] text-gray-400 ml-2") 공통 문서: {{comparisonResult.common_doc_count}}건

                //- ---- 비교 분석 요약 ----
                div(*ngIf="comparisonResult.analysis", class="space-y-4")
                    //- 요약 카드
                    div(class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-xl border border-gray-200 px-5 py-4")
                        div(class="flex items-center gap-2 mb-2.5")
                            svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4 text-rose-500")
                                path(stroke-linecap="round", stroke-linejoin="round", d="M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z")
                            h3(class="text-[13px] font-semibold text-gray-900") 비교 분석 요약
                        p(class="text-[12px] text-gray-700 leading-relaxed") {{comparisonResult.analysis.summary}}

                    //- 키워드 비교
                    div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
                        //- A 고유 키워드
                        div(class="bg-white rounded-lg border border-blue-200 px-4 py-3")
                            h4(class="text-[12px] font-semibold text-blue-700 mb-2 flex items-center gap-1.5")
                                span(class="inline-block w-2 h-2 rounded-full bg-blue-500")
                                | {{comparisonResult.method_a}} 고유 키워드
                            div(class="flex flex-wrap gap-1.5")
                                span(*ngFor="let kw of comparisonResult.analysis.keywords_a", class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-0.5 text-[11px] font-medium text-blue-700 border border-blue-200") {{kw}}
                            div(*ngIf="!comparisonResult.analysis.keywords_a?.length", class="text-[11px] text-gray-400") 고유 키워드 없음
                        //- B 고유 키워드
                        div(class="bg-white rounded-lg border border-purple-200 px-4 py-3")
                            h4(class="text-[12px] font-semibold text-purple-700 mb-2 flex items-center gap-1.5")
                                span(class="inline-block w-2 h-2 rounded-full bg-purple-500")
                                | {{comparisonResult.method_b}} 고유 키워드
                            div(class="flex flex-wrap gap-1.5")
                                span(*ngFor="let kw of comparisonResult.analysis.keywords_b", class="inline-flex items-center rounded-full bg-purple-50 px-2.5 py-0.5 text-[11px] font-medium text-purple-700 border border-purple-200") {{kw}}
                            div(*ngIf="!comparisonResult.analysis.keywords_b?.length", class="text-[11px] text-gray-400") 고유 키워드 없음

                    //- 공통 키워드
                    div(*ngIf="comparisonResult.analysis.keywords_common?.length > 0", class="bg-white rounded-lg border border-gray-200 px-4 py-3")
                        h4(class="text-[12px] font-semibold text-gray-700 mb-2 flex items-center gap-1.5")
                            svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-3.5 text-gray-500")
                                path(stroke-linecap="round", stroke-linejoin="round", d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z")
                            | 공통 키워드
                        div(class="flex flex-wrap gap-1.5")
                            span(*ngFor="let kw of comparisonResult.analysis.keywords_common", class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-[11px] font-medium text-gray-600 border border-gray-200") {{kw}}

                    //- 차이점 / 공통점
                    div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
                        div(*ngIf="comparisonResult.analysis.differences?.length > 0", class="bg-white rounded-lg border border-amber-200 px-4 py-3")
                            h4(class="text-[12px] font-semibold text-amber-700 mb-2 flex items-center gap-1.5")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-3.5 text-amber-500")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5")
                                | 차이점
                            ul(class="space-y-1.5")
                                li(*ngFor="let d of comparisonResult.analysis.differences", class="text-[11px] text-gray-700 leading-relaxed flex items-start gap-1.5")
                                    span(class="text-amber-400 mt-0.5 shrink-0") •
                                    span {{d}}
                        div(*ngIf="comparisonResult.analysis.commonalities?.length > 0", class="bg-white rounded-lg border border-green-200 px-4 py-3")
                            h4(class="text-[12px] font-semibold text-green-700 mb-2 flex items-center gap-1.5")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-3.5 text-green-500")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244")
                                | 공통점
                            ul(class="space-y-1.5")
                                li(*ngFor="let c of comparisonResult.analysis.commonalities", class="text-[11px] text-gray-700 leading-relaxed flex items-start gap-1.5")
                                    span(class="text-green-400 mt-0.5 shrink-0") •
                                    span {{c}}

                //- ---- 관련 문서 목록 ----
                div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
                    div(class="space-y-2")
                        h3(class="text-[13px] font-semibold text-blue-700 mb-2") {{comparisonResult.method_a}} ({{comparisonResult.results_a?.length}}건)
                        div(*ngFor="let r of comparisonResult.results_a?.slice(0, 5)", class="bg-blue-50/50 rounded-lg px-3 py-2 border border-blue-100")
                            div(class="flex items-center justify-between mb-1")
                                span(class="text-[11px] font-medium text-gray-900 truncate") {{r.filename}}
                                span(class="text-[10px] font-mono text-blue-600") {{(r.score * 100).toFixed(1)}}%
                            p(class="text-[11px] text-gray-600 line-clamp-2") {{r.text}}
                    div(class="space-y-2")
                        h3(class="text-[13px] font-semibold text-purple-700 mb-2") {{comparisonResult.method_b}} ({{comparisonResult.results_b?.length}}건)
                        div(*ngFor="let r of comparisonResult.results_b?.slice(0, 5)", class="bg-purple-50/50 rounded-lg px-3 py-2 border border-purple-100")
                            div(class="flex items-center justify-between mb-1")
                                span(class="text-[11px] font-medium text-gray-900 truncate") {{r.filename}}
                                span(class="text-[10px] font-mono text-purple-600") {{(r.score * 100).toFixed(1)}}%
                            p(class="text-[11px] text-gray-600 line-clamp-2") {{r.text}}

    //- Diagnostic Methods Overview
    div(class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden")
        div(class="px-6 py-4 border-b border-gray-100 flex items-center justify-between")
            h2(class="text-[15px] font-semibold text-gray-900") 진단 방법 현황
            button((click)="loadOverview()", [disabled]="overviewLoading", class="text-[12px] text-rose-600 hover:text-rose-500 font-medium")
                span(*ngIf="!overviewLoading") 현황 조회
                span(*ngIf="overviewLoading") 조회 중...
        div(class="px-6 py-5")
            div(*ngIf="overviewLoading", class="flex items-center justify-center gap-2 py-8")
                svg(class="animate-spin size-5 text-rose-600", viewBox="0 0 24 24")
                    circle(class="opacity-25", cx="12", cy="12", r="10", stroke="currentColor", stroke-width="4", fill="none")
                    path(class="opacity-75", fill="currentColor", d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z")
            div(*ngIf="!overviewLoading && diagnosticOverview.length === 0", class="text-center py-8")
                p(class="text-[13px] text-gray-400") '현황 조회' 버튼을 클릭하여 진단 방법별 문헌 현황을 확인하세요.
            div(*ngIf="!overviewLoading && diagnosticOverview.length > 0", class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3")
                div(*ngFor="let item of diagnosticOverview", class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-100 hover:border-rose-200 transition-colors cursor-pointer", (click)="selectedDiagType = item.method; switchTab('search')")
                    div(class="flex items-center justify-between")
                        span(class="text-[13px] font-medium text-gray-900") {{item.method}}
                        span(class="text-[11px] font-mono text-rose-600") {{(item.max_score * 100).toFixed(0)}}%
                    div(class="flex items-center gap-2 mt-1.5")
                        span(class="text-[11px] text-gray-500") {{item.doc_count}}개 문서
                        div(class="flex-1 bg-gray-200 rounded-full h-1.5")
                            div(class="bg-rose-400 h-1.5 rounded-full", [style.width.%]="item.max_score * 100")

        //- ========================================
        //- Boltzmann Plot 탭
        //- ========================================
        div(*ngIf="activeTab === 'boltzmann'")
            div(class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6")
                h2(class="text-[15px] font-semibold text-gray-900 mb-2") Boltzmann Plot 분석
                p(class="text-[13px] text-gray-500 mb-4") OES 스펙트럼 데이터에서 Boltzmann plot을 통해 전자 온도(Te)를 추정합니다. 각 줄에 "파장(nm), 강도, 상태에너지(eV), 통계가중치, 전이확률(s⁻¹)" 형식으로 입력하세요.
                div(class="space-y-4")
                    textarea(class="w-full px-4 py-3 border border-gray-300 rounded-lg text-[13px] font-mono focus:ring-2 focus:ring-rose-200 focus:border-rose-400", rows="6", placeholder="696.5, 5200, 13.33, 3, 6.39e6\n706.7, 3800, 13.30, 5, 3.80e6\n738.4, 4100, 13.28, 3, 8.47e6\n750.4, 8900, 13.48, 1, 4.45e7\n763.5, 12000, 13.17, 3, 2.45e7", [(ngModel)]="boltzmannData")
                    button((click)="analyzeBoltzmann()", [disabled]="boltzmannLoading || !boltzmannData.trim()", class="px-6 py-2.5 bg-rose-600 text-white text-[13px] font-medium rounded-lg hover:bg-rose-700 disabled:opacity-50 transition-colors")
                        span(*ngIf="!boltzmannLoading") Boltzmann Plot 분석
                        span(*ngIf="boltzmannLoading") 분석 중...

            div(*ngIf="boltzmannResult", class="bg-white rounded-xl shadow-sm border border-gray-200 p-6")
                h3(class="text-[15px] font-semibold text-gray-900 mb-4") 분석 결과
                div(class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6")
                    div(class="bg-rose-50 rounded-lg p-4 text-center")
                        div(class="text-[11px] text-rose-600 font-medium mb-1") 전자 온도 (Te)
                        div(class="text-lg font-bold text-gray-900") {{boltzmannResult.Te_eV}} eV
                    div(class="bg-rose-50 rounded-lg p-4 text-center")
                        div(class="text-[11px] text-rose-600 font-medium mb-1") 전자 온도 (K)
                        div(class="text-lg font-bold text-gray-900") {{boltzmannResult.Te_K}} K
                    div(class="bg-rose-50 rounded-lg p-4 text-center")
                        div(class="text-[11px] text-rose-600 font-medium mb-1") R² 적합도
                        div(class="text-lg font-bold text-gray-900") {{boltzmannResult.r_squared}}
                    div(class="bg-rose-50 rounded-lg p-4 text-center")
                        div(class="text-[11px] text-rose-600 font-medium mb-1") 데이터 포인트
                        div(class="text-lg font-bold text-gray-900") {{boltzmannResult.n_points}}
                div(*ngIf="boltzmannResult.points", class="overflow-x-auto")
                    table(class="w-full text-[13px]")
                        thead
                            tr(class="bg-gray-50")
                                th(class="px-4 py-2 text-left text-gray-600") 파장 (nm)
                                th(class="px-4 py-2 text-left text-gray-600") E_upper (eV)
                                th(class="px-4 py-2 text-left text-gray-600") ln(I·λ/g·A)
                        tbody
                            tr(*ngFor="let pt of boltzmannResult.points", class="border-t border-gray-100")
                                td(class="px-4 py-2 font-mono") {{pt.wavelength}}
                                td(class="px-4 py-2 font-mono") {{pt.energy}}
                                td(class="px-4 py-2 font-mono") {{pt.ln_value}}

        //- ========================================
        //- Langmuir Probe 탭
        //- ========================================
        div(*ngIf="activeTab === 'langmuir'")
            div(class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6")
                h2(class="text-[15px] font-semibold text-gray-900 mb-2") Langmuir Probe I-V 분석
                p(class="text-[13px] text-gray-500 mb-4") I-V 특성 데이터에서 플라즈마 파라미터(ne, Te, Vp, Vf)를 추출합니다. 각 줄에 "전압(V), 전류(A)" 형식으로 입력하세요.
                div(class="space-y-4")
                    textarea(class="w-full px-4 py-3 border border-gray-300 rounded-lg text-[13px] font-mono focus:ring-2 focus:ring-rose-200 focus:border-rose-400", rows="6", placeholder="-50, -0.0012\n-40, -0.0010\n-30, -0.0008\n-20, -0.0003\n-10, 0.0015\n0, 0.0085\n10, 0.025\n20, 0.045\n30, 0.048\n40, 0.049", [(ngModel)]="langmuirData")
                    button((click)="analyzeLangmuir()", [disabled]="langmuirLoading || !langmuirData.trim()", class="px-6 py-2.5 bg-rose-600 text-white text-[13px] font-medium rounded-lg hover:bg-rose-700 disabled:opacity-50 transition-colors")
                        span(*ngIf="!langmuirLoading") Langmuir 분석
                        span(*ngIf="langmuirLoading") 분석 중...

            div(*ngIf="langmuirResult", class="bg-white rounded-xl shadow-sm border border-gray-200 p-6")
                h3(class="text-[15px] font-semibold text-gray-900 mb-4") 플라즈마 파라미터
                div(class="grid grid-cols-2 md:grid-cols-4 gap-4")
                    div(class="bg-rose-50 rounded-lg p-4 text-center")
                        div(class="text-[11px] text-rose-600 font-medium mb-1") 전자 밀도 (ne)
                        div(class="text-lg font-bold text-gray-900") {{langmuirResult.ne}}
                        div(class="text-[11px] text-gray-500") m⁻³
                    div(class="bg-rose-50 rounded-lg p-4 text-center")
                        div(class="text-[11px] text-rose-600 font-medium mb-1") 전자 온도 (Te)
                        div(class="text-lg font-bold text-gray-900") {{langmuirResult.Te_eV}}
                        div(class="text-[11px] text-gray-500") eV
                    div(class="bg-rose-50 rounded-lg p-4 text-center")
                        div(class="text-[11px] text-rose-600 font-medium mb-1") 플라즈마 전위 (Vp)
                        div(class="text-lg font-bold text-gray-900") {{langmuirResult.Vp}}
                        div(class="text-[11px] text-gray-500") V
                    div(class="bg-rose-50 rounded-lg p-4 text-center")
                        div(class="text-[11px] text-rose-600 font-medium mb-1") 부유 전위 (Vf)
                        div(class="text-lg font-bold text-gray-900") {{langmuirResult.Vf}}
                        div(class="text-[11px] text-gray-500") V

        //- ========================================
        //- Actinometry 탭
        //- ========================================
        div(*ngIf="activeTab === 'actinometry'")
            div(class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6")
                h2(class="text-[15px] font-semibold text-gray-900 mb-2") Actinometry 분석
                p(class="text-[13px] text-gray-500 mb-4") OES 스펙트럼에서 actinometry를 통해 반응성 종의 상대 밀도를 추정합니다. 각 줄에 "파장(nm), 강도, 종(species)" 형식으로 입력하세요.
                div(class="space-y-4")
                    div(class="flex gap-3")
                        div(class="flex-1")
                            label(class="block text-[12px] font-medium text-gray-600 mb-1") 기준 가스 (Reference)
                            select(class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-[13px] focus:ring-2 focus:ring-rose-200 focus:border-rose-400", [(ngModel)]="actinometryRefGas")
                                option(value="Ar") Ar (750.4 nm)
                                option(value="He") He (706.5 nm)
                                option(value="Ne") Ne (585.2 nm)
                    textarea(class="w-full px-4 py-3 border border-gray-300 rounded-lg text-[13px] font-mono focus:ring-2 focus:ring-rose-200 focus:border-rose-400", rows="6", placeholder="703.7, 4500, F\n750.4, 8900, Ar\n777.4, 6200, O\n844.6, 3100, O\n686.1, 2800, F", [(ngModel)]="actinometryData")
                    button((click)="analyzeActinometry()", [disabled]="actinometryLoading || !actinometryData.trim()", class="px-6 py-2.5 bg-rose-600 text-white text-[13px] font-medium rounded-lg hover:bg-rose-700 disabled:opacity-50 transition-colors")
                        span(*ngIf="!actinometryLoading") Actinometry 분석
                        span(*ngIf="actinometryLoading") 분석 중...

            div(*ngIf="actinometryResult", class="bg-white rounded-xl shadow-sm border border-gray-200 p-6")
                h3(class="text-[15px] font-semibold text-gray-900 mb-4") 분석 결과
                div(*ngIf="actinometryResult.ref_gas", class="text-[13px] text-gray-600 mb-4") 기준 가스: {{actinometryResult.ref_gas}} ({{actinometryResult.ref_wavelength}} nm, 강도: {{actinometryResult.ref_intensity}})
                div(*ngIf="actinometryResult.species", class="space-y-3")
                    div(*ngFor="let sp of actinometryResult.species", class="bg-rose-50 rounded-lg p-4")
                        div(class="flex items-center justify-between mb-2")
                            span(class="text-[13px] font-semibold text-gray-900") {{sp.name}} ({{sp.wavelength}} nm)
                            span(class="text-[13px] font-mono text-rose-600") 상대 밀도: {{sp.relative_density}}
                        div(class="flex items-center gap-4 text-[12px] text-gray-500")
                            span 원본 강도: {{sp.intensity}}
                            span 정규화 비율: {{sp.ratio}}
