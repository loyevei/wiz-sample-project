nav(class="sticky top-0 z-20 bg-white shadow")
    div(class="max-w-6xl px-4 sm:px-6 lg:px-8 py-3")
        div(class="flex items-center justify-between")
            h1(class="flex text-lg font-semibold text-zinc-950 gap-x-3 items-center")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-6 text-teal-600")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z")
                span 협업

div(class="max-w-6xl pt-6 px-4 sm:px-6 lg:px-8 pb-8 space-y-6")
    //- Tab Navigation
    div(class="bg-white rounded-xl border border-gray-200 shadow-sm")
        div(class="border-b border-gray-200 overflow-x-auto")
            nav(class="flex -mb-px px-4 min-w-max")
                button(*ngFor="let tab of tabs", (click)="switchTab(tab.id)", class="px-4 py-3 text-[13px] font-medium border-b-2 transition-colors whitespace-nowrap", [ngClass]="activeTab === tab.id ? 'border-teal-500 text-teal-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'") {{tab.label}}

        //- ===== Tab: 프로젝트 =====
        div(*ngIf="activeTab === 'projects'", class="px-6 py-5")
            div(class="flex items-center justify-between mb-5")
                div(class="flex items-center gap-3")
                    h2(class="text-[15px] font-semibold text-gray-900") 프로젝트 관리
                    span(class="text-xs text-gray-400") {{projects.length}}개
                div(class="flex items-center gap-2")
                    input(type="text", [(ngModel)]="projectSearch", placeholder="프로젝트 검색...", class="px-3 py-1.5 rounded-lg border border-gray-300 text-[12px] w-48 focus:ring-2 focus:ring-teal-500 outline-none")
                    button((click)="openProjectForm()", class="inline-flex items-center gap-1.5 rounded-lg bg-teal-600 px-3.5 py-1.5 text-[13px] font-semibold text-white shadow-sm hover:bg-teal-500 transition-all active:scale-95")
                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                            path(stroke-linecap="round", stroke-linejoin="round", d="M12 4.5v15m7.5-7.5h-15")
                        span 새 프로젝트

            //- Project Cards Grid
            div(*ngIf="filteredProjects().length === 0", class="text-center py-12 text-[13px] text-gray-400") 프로젝트가 없습니다.

            div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4", *ngIf="filteredProjects().length > 0")
                div(*ngFor="let project of filteredProjects()", class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-shadow group")
                    div(class="flex items-start justify-between mb-3")
                        div(class="flex items-center gap-2.5 min-w-0")
                            div(class="flex-shrink-0 w-9 h-9 rounded-lg bg-teal-50 flex items-center justify-center")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5 text-teal-600")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z")
                            h3(class="text-[13px] font-semibold text-gray-900 truncate") {{project.name}}
                        span(class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium flex-shrink-0", [ngClass]="getStatusClass(project.status)") {{getStatusLabel(project.status)}}

                    p(class="text-[12px] text-gray-500 mb-4 line-clamp-2 min-h-[2.5rem]") {{project.description || '설명 없음'}}
                    div(class="flex flex-wrap gap-1.5 mb-4")
                        span(*ngIf="project.collection", class="inline-flex items-center rounded-full bg-sky-50 px-2 py-0.5 text-[10px] font-medium text-sky-700 border border-sky-200") {{project.collection}}
                        span(*ngIf="project.tags", class="inline-flex items-center rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-medium text-amber-700 border border-amber-200") {{project.tags}}

                    div(class="flex items-center justify-between pt-3 border-t border-gray-100")
                        div(class="flex items-center gap-3")
                            div(class="flex items-center gap-1 text-[11px] text-gray-400")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-3.5")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z")
                                span {{project.members?.length || 0}}명
                            span(class="text-[11px] text-gray-400") {{formatDate(project.created)}}
                        div(class="flex items-center gap-1")
                            button(*ngIf="project.collection", (click)="openProjectCollection(project); $event.stopPropagation()", class="inline-flex items-center rounded-lg border border-sky-200 bg-sky-50 px-2.5 py-1 text-[11px] font-medium text-sky-700 hover:bg-sky-100") 컬렉션 열기
                            button((click)="generateProjectReport(project); $event.stopPropagation()", class="inline-flex items-center rounded-lg border border-indigo-200 bg-indigo-50 px-2.5 py-1 text-[11px] font-medium text-indigo-700 hover:bg-indigo-100") 보고서 생성
                        div(class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity")
                            button((click)="openProjectForm(project); $event.stopPropagation()", class="p-1 rounded hover:bg-gray-100 text-gray-400 hover:text-teal-600 transition-colors")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125")
                            button((click)="deleteProject(project.id); $event.stopPropagation()", class="p-1 rounded hover:bg-gray-100 text-gray-400 hover:text-red-500 transition-colors")
                                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0")

        //- ===== Tab: 토론 =====
        div(*ngIf="activeTab === 'discussions'", class="px-6 py-5")
            //- Discussion List View
            div(*ngIf="!selectedDiscussion")
                div(class="flex items-center justify-between mb-5")
                    div(class="flex items-center gap-3")
                        h2(class="text-[15px] font-semibold text-gray-900") 토론 게시판
                        span(class="text-xs text-gray-400") {{discussions.length}}개
                    div(class="flex items-center gap-2")
                        input(type="text", [(ngModel)]="discussionSearch", placeholder="토론 검색...", class="px-3 py-1.5 rounded-lg border border-gray-300 text-[12px] w-48 focus:ring-2 focus:ring-teal-500 outline-none")
                        button((click)="openDiscussionForm()", class="inline-flex items-center gap-1.5 rounded-lg bg-teal-600 px-3.5 py-1.5 text-[13px] font-semibold text-white shadow-sm hover:bg-teal-500 transition-all active:scale-95")
                            svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                                path(stroke-linecap="round", stroke-linejoin="round", d="M12 4.5v15m7.5-7.5h-15")
                            span 새 토론

                div(*ngIf="filteredDiscussions().length === 0", class="text-center py-12 text-[13px] text-gray-400") 토론이 없습니다.

                div(class="space-y-3", *ngIf="filteredDiscussions().length > 0")
                    div(*ngFor="let disc of filteredDiscussions()", (click)="selectDiscussion(disc)", class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md hover:border-teal-200 transition-all cursor-pointer group")
                        div(class="flex items-start justify-between")
                            div(class="flex-1 min-w-0")
                                div(class="flex items-center gap-2 mb-1")
                                    h3(class="text-[13px] font-semibold text-gray-900 truncate") {{disc.title}}
                                    span(*ngIf="disc.replies?.length > 0", class="inline-flex items-center rounded-full bg-teal-50 text-teal-700 px-1.5 py-0.5 text-[10px] font-medium")
                                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-3 mr-0.5")
                                            path(stroke-linecap="round", stroke-linejoin="round", d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z")
                                        | {{disc.replies?.length || 0}}
                                p(class="text-[12px] text-gray-500 line-clamp-1") {{disc.content}}
                            div(class="flex items-center gap-2 ml-4 flex-shrink-0")
                                div(class="text-right")
                                    div(class="text-[11px] text-gray-500") {{disc.author || '익명'}}
                                    div(class="text-[11px] text-gray-400") {{timeAgo(disc.updated || disc.created)}}
                                div(class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity")
                                    button((click)="openDiscussionForm(disc); $event.stopPropagation()", class="p-1 rounded hover:bg-gray-100 text-gray-400 hover:text-teal-600 transition-colors")
                                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-3.5")
                                            path(stroke-linecap="round", stroke-linejoin="round", d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125")
                                    button((click)="deleteDiscussion(disc.id); $event.stopPropagation()", class="p-1 rounded hover:bg-gray-100 text-gray-400 hover:text-red-500 transition-colors")
                                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-3.5")
                                            path(stroke-linecap="round", stroke-linejoin="round", d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0")

            //- Discussion Detail View
            div(*ngIf="selectedDiscussion")
                div(class="flex items-center gap-2 mb-5")
                    button((click)="backToList()", class="inline-flex items-center gap-1 text-[13px] text-gray-500 hover:text-teal-600 transition-colors")
                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                            path(stroke-linecap="round", stroke-linejoin="round", d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18")
                        span 목록으로
                    span(class="text-gray-300") |
                    h2(class="text-[15px] font-semibold text-gray-900") {{selectedDiscussion.title}}

                //- Original Post
                div(class="bg-white rounded-xl border border-gray-200 p-5 mb-4")
                    div(class="flex items-center gap-2 mb-3")
                        div(class="w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center text-[12px] font-bold text-teal-700") {{(selectedDiscussion.author || '익명').charAt(0)}}
                        div
                            div(class="text-[13px] font-medium text-gray-900") {{selectedDiscussion.author || '익명'}}
                            div(class="text-[11px] text-gray-400") {{formatDateTime(selectedDiscussion.created)}}
                    p(class="text-[13px] text-gray-700 whitespace-pre-wrap") {{selectedDiscussion.content}}

                //- Replies
                div(*ngIf="selectedDiscussion.replies?.length > 0", class="space-y-3 mb-4")
                    div(class="text-[12px] font-medium text-gray-500 mb-2") 답글 {{selectedDiscussion.replies.length}}개
                    div(*ngFor="let reply of selectedDiscussion.replies", class="bg-gray-50 rounded-lg border border-gray-100 p-4 ml-6")
                        div(class="flex items-center gap-2 mb-2")
                            div(class="w-6 h-6 rounded-full bg-gray-200 flex items-center justify-center text-[10px] font-bold text-gray-600") {{(reply.author || '익명').charAt(0)}}
                            div(class="text-[12px] font-medium text-gray-700") {{reply.author || '익명'}}
                            div(class="text-[11px] text-gray-400") {{timeAgo(reply.created)}}
                        p(class="text-[13px] text-gray-600 whitespace-pre-wrap") {{reply.content}}

                //- Reply Form
                div(class="bg-white rounded-xl border border-gray-200 p-4")
                    div(class="text-[12px] font-medium text-gray-700 mb-2") 답글 작성
                    textarea([(ngModel)]="replyContent", rows="3", placeholder="답글을 입력하세요...", class="w-full px-3 py-2 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-teal-500 outline-none resize-none")
                    div(class="flex justify-end mt-2")
                        button((click)="submitReply()", [disabled]="!replyContent.trim()", class="inline-flex items-center gap-1.5 rounded-lg bg-teal-600 px-4 py-1.5 text-[13px] font-semibold text-white shadow-sm hover:bg-teal-500 disabled:opacity-50 transition-all")
                            svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4")
                                path(stroke-linecap="round", stroke-linejoin="round", d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5")
                            span 답글 달기

        //- ===== Tab: 활동/알림 =====
        div(*ngIf="activeTab === 'activity'", class="px-6 py-5")
            div(class="flex items-center justify-between mb-5")
                h2(class="text-[15px] font-semibold text-gray-900") 최근 활동
                span(class="text-xs text-gray-400") 최근 50건

            div(*ngIf="activities.length === 0", class="text-center py-12 text-[13px] text-gray-400") 활동 기록이 없습니다.

            //- Activity Timeline
            div(class="relative", *ngIf="activities.length > 0")
                //- Timeline line
                div(class="absolute left-5 top-0 bottom-0 w-px bg-gray-200")

                div(class="space-y-0")
                    div(*ngFor="let act of activities; let last = last", class="relative flex gap-4 pb-6", [class.pb-0]="last")
                        //- Timeline dot
                        div(class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center", [ngClass]="getActivityColor(act.type)")
                            svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4")
                                path(stroke-linecap="round", stroke-linejoin="round", [attr.d]="getActivityIcon(act.type)")

                        //- Content
                        div(class="flex-1 min-w-0 pt-1.5")
                            div(class="flex items-center justify-between")
                                p(class="text-[13px] text-gray-900") {{act.message}}
                                span(class="text-[11px] text-gray-400 flex-shrink-0 ml-2") {{timeAgo(act.created)}}
                            p(*ngIf="act.detail", class="text-[12px] text-gray-500 mt-0.5") {{act.detail}}

//- ===== Project Form Modal =====
div(*ngIf="showProjectForm", class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm")
    div(class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 overflow-hidden")
        div(class="px-6 py-5 border-b border-gray-100")
            h3(class="text-[15px] font-semibold text-gray-900") {{editingProject ? '프로젝트 수정' : '새 프로젝트'}}
            p(class="text-[13px] text-gray-500 mt-1") 프로젝트 정보를 입력하세요.

        div(class="px-6 py-6 space-y-4")
            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 프로젝트 이름 *
                input(type="text", [(ngModel)]="projectForm.name", placeholder="프로젝트 이름", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 focus:outline-none")

            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 설명
                textarea([(ngModel)]="projectForm.description", rows="3", placeholder="프로젝트에 대한 간단한 설명", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 focus:outline-none resize-none")

            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 프로젝트 목표
                textarea([(ngModel)]="projectForm.objective", rows="3", placeholder="프로젝트 목표, 검증하려는 가설, 기대 결과", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 focus:outline-none resize-none")

            div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 연결 컬렉션
                    select([(ngModel)]="projectForm.collection", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 focus:outline-none")
                        option(value="") 선택 안 함
                        option(*ngFor="let collection of collections", [value]="collection.name") {{collection.name}}
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 태그
                    input(type="text", [(ngModel)]="projectForm.tags", placeholder="etching, report, plasma", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 focus:outline-none")

            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 멤버 (쉼표로 구분)
                input(type="text", [(ngModel)]="projectForm.members", placeholder="user1, user2, user3", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 focus:outline-none")

            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 상태
                select([(ngModel)]="projectForm.status", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 focus:outline-none")
                    option(value="active") 진행 중
                    option(value="paused") 일시중지
                    option(value="completed") 완료
                    option(value="archived") 보관

        div(class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-2")
            button((click)="cancelProjectForm()", class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-[13px] font-medium text-gray-700 shadow-sm hover:bg-gray-50") 취소
            button((click)="saveProject()", class="inline-flex items-center rounded-lg bg-teal-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-teal-500") {{editingProject ? '수정' : '생성'}}

//- ===== Discussion Form Modal =====
div(*ngIf="showDiscussionForm", class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm")
    div(class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 overflow-hidden")
        div(class="px-6 py-5 border-b border-gray-100")
            h3(class="text-[15px] font-semibold text-gray-900") {{editingDiscussion ? '토론 수정' : '새 토론'}}
            p(class="text-[13px] text-gray-500 mt-1") 토론 주제를 작성하세요.

        div(class="px-6 py-6 space-y-4")
            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 제목 *
                input(type="text", [(ngModel)]="discussionForm.title", placeholder="토론 제목", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 focus:outline-none")

            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 내용
                textarea([(ngModel)]="discussionForm.content", rows="6", placeholder="토론 내용을 작성하세요...", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 focus:outline-none resize-none")

        div(class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-2")
            button((click)="cancelDiscussionForm()", class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-[13px] font-medium text-gray-700 shadow-sm hover:bg-gray-50") 취소
            button((click)="saveDiscussion()", class="inline-flex items-center rounded-lg bg-teal-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-teal-500") {{editingDiscussion ? '수정' : '작성'}}

div(*ngIf="selectedReport", class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm")
    div(class="bg-white rounded-xl shadow-xl w-full max-w-4xl mx-4 overflow-hidden")
        div(class="px-6 py-5 border-b border-gray-100 flex items-center justify-between")
            div
                h3(class="text-[15px] font-semibold text-gray-900") 프로젝트 보고서 미리보기
                p(class="text-[13px] text-gray-500 mt-1") {{selectedReport.project_name}}
            button((click)="closeReport()", class="text-[13px] text-gray-500 hover:text-gray-700") 닫기
        div(class="grid grid-cols-1 lg:grid-cols-2 gap-0")
            div(class="p-6 border-r border-gray-100 max-h-[70vh] overflow-y-auto")
                h4(class="text-[13px] font-semibold text-gray-700 mb-3") 보고서 초안
                pre(class="whitespace-pre-wrap text-[12px] text-gray-600 leading-relaxed font-sans") {{selectedReport.markdown}}
            div(class="p-6 max-h-[70vh] overflow-y-auto")
                h4(class="text-[13px] font-semibold text-gray-700 mb-3") 발표 자료 구성
                div(class="space-y-3")
                    div(*ngFor="let slide of selectedReport.slides; let i = index", class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3")
                        div(class="text-[12px] font-semibold text-gray-900 mb-2") {{i + 1}}. {{slide.title}}
                        ul(class="space-y-1")
                            li(*ngFor="let bullet of slide.bullets", class="text-[12px] text-gray-600") • {{bullet}}
