//- Floating Chat Button
button((click)="toggleChat()", class="fixed bottom-6 right-6 z-[9999] w-14 h-14 rounded-full bg-gradient-to-br from-cyan-500 to-blue-600 text-white shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200 flex items-center justify-center", [ngClass]="isOpen ? 'scale-0 opacity-0 pointer-events-none' : 'scale-100 opacity-100'")
    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-6")
        path(stroke-linecap="round", stroke-linejoin="round", d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z")

//- Chat Window
div(class="fixed bottom-6 right-6 z-[9999] transition-all duration-300 origin-bottom-right", [ngClass]="isOpen ? 'scale-100 opacity-100' : 'scale-0 opacity-0 pointer-events-none'")
    div(class="w-[420px] h-[600px] bg-white rounded-2xl shadow-2xl border border-gray-200 flex flex-col overflow-hidden")

        //- Header
        div(class="flex items-center justify-between px-4 py-3 bg-gradient-to-r from-cyan-500 to-blue-600 text-white flex-shrink-0")
            div(class="flex items-center gap-2")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-5")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z")
                span(class="text-[14px] font-semibold") 플라즈마 AI 어시스턴트
            div(class="flex items-center gap-1")
                //- Collection indicator
                button(*ngIf="collectionSelected && selectedCollection", (click)="changeCollection()", class="flex items-center gap-1 px-2 py-0.5 rounded-md bg-white/20 hover:bg-white/30 transition-colors text-[10px]", title="컬렉션 변경")
                    span 📦
                    span {{selectedCollection}}
                button((click)="clearChat()", class="p-1 rounded-lg hover:bg-white/20 transition-colors", title="대화 초기화")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182")
                button((click)="toggleChat()", class="p-1 rounded-lg hover:bg-white/20 transition-colors", title="닫기")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M19.5 8.25l-7.5 7.5-7.5-7.5")

        //- Collection Selection Screen (shown before chat starts)
        div(*ngIf="!collectionSelected", class="flex-1 min-h-0 overflow-y-auto px-4 py-6 bg-gray-50")
            div(class="flex flex-col items-center justify-center h-full")
                //- Loading
                div(*ngIf="collectionsLoading", class="flex flex-col items-center gap-3")
                    div(class="w-10 h-10 border-3 border-cyan-500 border-t-transparent rounded-full animate-spin")
                    p(class="text-[13px] text-gray-500") 데이터베이스 로딩 중...

                //- Collection List
                div(*ngIf="!collectionsLoading", class="w-full")
                    div(class="text-center mb-5")
                        div(class="w-12 h-12 rounded-full bg-gradient-to-br from-cyan-100 to-blue-100 flex items-center justify-center mx-auto mb-3")
                            span(class="text-xl") 📦
                        p(class="text-[14px] font-semibold text-gray-800") 데이터베이스 선택
                        p(class="text-[11px] text-gray-400 mt-1") 검색할 논문 컬렉션을 선택하세요

                    //- No collections
                    div(*ngIf="collections.length === 0", class="text-center py-6")
                        p(class="text-[13px] text-gray-500") 사용 가능한 컬렉션이 없습니다.
                        p(class="text-[11px] text-gray-400 mt-1") 먼저 임베딩 페이지에서 PDF를 업로드하세요.

                    //- Collection buttons (pill style)
                    div(class="flex flex-wrap gap-2 justify-center")
                        button(*ngFor="let col of collections", (click)="selectCollection(col.name)", class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 rounded-full text-[12px] font-medium text-gray-700 hover:border-cyan-400 hover:bg-cyan-50 hover:text-cyan-700 transition-all shadow-sm hover:shadow", [ngClass]="selectedCollection === col.name ? 'border-cyan-500 bg-cyan-50 text-cyan-700 shadow ring-1 ring-cyan-200' : ''")
                            span 📄
                            span {{col.name}}
                            span(class="text-[10px] text-gray-400 ml-0.5") ({{col.total_docs}})

        //- Chat Body (shown after collection is selected)
        div(*ngIf="collectionSelected", #chatBody="", class="flex-1 min-h-0 overflow-y-auto px-4 py-3 space-y-3 bg-gray-50")

            //- Welcome (empty state)
            div(*ngIf="chatMessages.length === 0", class="flex flex-col items-center justify-center h-full text-center")
                div(class="w-16 h-16 rounded-full bg-gradient-to-br from-cyan-100 to-blue-100 flex items-center justify-center mb-3")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-8 text-cyan-600")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z")
                p(class="text-[13px] font-medium text-gray-700 mb-1") 무엇을 도와드릴까요?
                p(class="text-[11px] text-gray-400 mb-4") 플라즈마 연구, 공정 예측, 데이터 분석 등을 도와드립니다
                div(class="grid grid-cols-1 gap-2 w-full max-w-[300px]")
                    button(*ngFor="let s of suggestions", (click)="sendChat(s.text)", class="flex items-center gap-2 px-3 py-2 bg-white border border-gray-200 rounded-xl text-left hover:border-cyan-300 hover:bg-cyan-50 transition-all text-[12px] text-gray-600")
                        span(class="text-base flex-shrink-0") {{s.icon}}
                        span(class="truncate") {{s.text}}

            //- Messages
            ng-container(*ngFor="let msg of chatMessages; let i = index")

                //- User Message
                div(*ngIf="msg.role === 'user'", class="flex justify-end")
                    div(class="max-w-[85%] px-3 py-2 rounded-2xl rounded-br-md bg-cyan-600 text-white text-[13px] leading-relaxed whitespace-pre-wrap") {{msg.content}}

                //- Assistant Message
                div(*ngIf="msg.role === 'assistant'", class="flex justify-start")
                    div(class="max-w-[90%] space-y-2")

                        //- Collapsed view
                        div(*ngIf="msg.collapsed", (click)="toggleCollapse(msg)", class="px-3 py-2 bg-white border border-gray-200 rounded-xl text-[12px] text-gray-500 cursor-pointer hover:bg-gray-50 transition-colors truncate")
                            span ▶ {{msg.content ? msg.content.slice(0, 60) + '...' : '(결과 보기)'}}

                        //- Expanded view
                        ng-container(*ngIf="!msg.collapsed")

                            //- Tool Calls
                            ng-container(*ngFor="let tc of msg.toolCalls")
                                //- Tool Use (호출)
                                div(*ngIf="tc.type === 'use'", class="flex items-start gap-2 px-3 py-2 bg-amber-50 border border-amber-200 rounded-xl text-[11px]")
                                    span(class="flex-shrink-0 text-sm") {{getToolIcon(tc.name)}}
                                    div(class="min-w-0 flex-1")
                                        div(class="font-semibold text-amber-700") {{getToolLabel(tc.name)}}
                                        div(*ngIf="tc.input", class="text-amber-600 mt-0.5 truncate", (click)="toggleToolCollapse(tc)", [title]="formatToolInput(tc.input)") {{formatToolInput(tc.input)}}

                                //- Tool Result
                                div(*ngIf="tc.type === 'result' && tc.name !== 'navigate_to_page'", class="flex items-start gap-2 px-3 py-2 bg-emerald-50 border border-emerald-200 rounded-xl text-[11px]")
                                    span(class="flex-shrink-0 text-sm") ✅
                                    div(class="min-w-0 flex-1")
                                        div(class="font-semibold text-emerald-700") {{getToolLabel(tc.name)}} 결과
                                        div(class="text-emerald-600 mt-0.5 whitespace-pre-wrap break-words") {{parseToolResult(tc.result)}}

                                //- Navigate Result Card
                                div(*ngIf="tc.type === 'result' && tc.name === 'navigate_to_page'", class="px-3 py-3 bg-gradient-to-r from-cyan-50 to-blue-50 border border-cyan-300 rounded-xl")
                                    div(class="flex items-center gap-2 mb-2")
                                        span(class="text-lg") 🧭
                                        span(class="text-[12px] font-semibold text-cyan-800") 페이지 이동
                                    div(class="text-[12px] text-cyan-700 mb-2") {{parseToolResult(tc.result)}}
                                    button((click)="navigateNow()", class="w-full px-3 py-1.5 bg-cyan-600 text-white text-[12px] font-medium rounded-lg hover:bg-cyan-500 transition-colors flex items-center justify-center gap-1")
                                        svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-3.5")
                                            path(stroke-linecap="round", stroke-linejoin="round", d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3")
                                        span 바로 이동

                            //- Text Content
                            div(*ngIf="msg.content", class="px-3 py-2 bg-white border border-gray-200 rounded-2xl rounded-bl-md text-[13px] leading-relaxed text-gray-800 whitespace-pre-wrap break-words") {{msg.content}}

            //- Loading indicator
            div(*ngIf="chatLoading", class="flex justify-start")
                div(class="px-3 py-2 bg-white border border-gray-200 rounded-2xl rounded-bl-md")
                    div(class="flex items-center gap-1")
                        div(class="w-2 h-2 bg-cyan-400 rounded-full animate-bounce", style="animation-delay: 0ms")
                        div(class="w-2 h-2 bg-cyan-400 rounded-full animate-bounce", style="animation-delay: 150ms")
                        div(class="w-2 h-2 bg-cyan-400 rounded-full animate-bounce", style="animation-delay: 300ms")

        //- Input Area (shown after collection is selected)
        div(*ngIf="collectionSelected", class="flex-shrink-0 border-t border-gray-200 bg-white px-3 py-3")
            div(class="flex items-end gap-2")
                div(class="flex-1 relative")
                    textarea(#chatInputEl="", [(ngModel)]="chatInput", (keydown)="onKeydown($event)", placeholder="질문을 입력하세요...", rows="1", class="w-full resize-none rounded-xl border border-gray-300 px-3 py-2 text-[13px] focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none max-h-24 overflow-y-auto", [disabled]="chatLoading")
                button(*ngIf="!chatLoading", (click)="sendChat()", [disabled]="!chatInput?.trim()", class="flex-shrink-0 w-9 h-9 rounded-xl bg-cyan-600 text-white flex items-center justify-center hover:bg-cyan-500 disabled:opacity-40 disabled:cursor-not-allowed transition-colors")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5")
                button(*ngIf="chatLoading", (click)="cancelChat()", class="flex-shrink-0 w-9 h-9 rounded-xl bg-red-500 text-white flex items-center justify-center hover:bg-red-400 transition-colors")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M5.25 7.5A2.25 2.25 0 017.5 5.25h9a2.25 2.25 0 012.25 2.25v9a2.25 2.25 0 01-2.25 2.25h-9a2.25 2.25 0 01-2.25-2.25v-9z")
