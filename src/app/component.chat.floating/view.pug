//- Floating Chat Button
button((click)="toggleChat()", class="fixed bottom-6 right-6 z-[9999] h-16 w-16 rounded-2xl bg-gradient-to-br from-fuchsia-500 via-violet-500 to-indigo-600 p-[1px] shadow-[0_20px_60px_rgba(168,85,247,0.38)] transition-all duration-300 hover:scale-105 hover:shadow-[0_24px_70px_rgba(217,70,239,0.42)]", [ngClass]="isOpen ? 'scale-0 opacity-0 pointer-events-none' : 'scale-100 opacity-100'")
    div(class="relative flex h-full w-full items-center justify-center overflow-hidden rounded-[15px] bg-[#14071f] text-white")
        div(class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(244,114,182,0.36),transparent_55%)]")
        img(src="/assets/brand/plasma-robot.svg", alt="Plasma robot", class="relative h-11 w-11 drop-shadow-[0_0_20px_rgba(244,114,182,0.38)]")
        div(class="absolute bottom-1 text-[9px] font-semibold tracking-[0.24em] text-fuchsia-100/90") PX14

//- Chat Window
div(class="fixed bottom-6 right-6 z-[9999] origin-bottom-right transition-all duration-300", [ngClass]="isOpen ? 'scale-100 opacity-100' : 'scale-0 opacity-0 pointer-events-none'")
    div(class="flex h-[720px] w-[460px] flex-col overflow-hidden rounded-[28px] border border-fuchsia-100 bg-white shadow-[0_28px_100px_rgba(76,29,149,0.24)]")
        div(class="flex items-start justify-between gap-3 border-b border-fuchsia-100 bg-gradient-to-r from-slate-950 via-violet-950 to-fuchsia-950 px-4 py-4 text-white")
            div(class="flex min-w-0 items-center gap-3")
                div(class="flex h-12 w-12 items-center justify-center rounded-2xl border border-fuchsia-300/30 bg-white/10 p-1")
                    img(src="/assets/brand/plasma-robot.svg", alt="Plasma robot", class="h-full w-full rounded-xl object-cover")
                div(class="min-w-0")
                    div(class="flex items-center gap-2")
                        span(class="truncate text-[14px] font-semibold") {{robotProfile.name}}
                        span(class="inline-flex items-center rounded-full border border-fuchsia-300/30 bg-fuchsia-400/10 px-2 py-0.5 text-[9px] font-semibold tracking-[0.2em] text-fuchsia-100") {{robotProfile.tag}}
                    p(class="mt-1 text-[11px] leading-5 text-fuchsia-100/80") {{robotProfile.subtitle}}
            div(class="flex flex-shrink-0 items-center gap-1")
                button(*ngIf="collectionSelected && selectedCollection", (click)="changeCollection()", class="inline-flex items-center gap-1 rounded-lg bg-white/10 px-2 py-1 text-[10px] font-medium text-fuchsia-50 transition-colors hover:bg-white/20", title="컬렉션 변경")
                    span 📦
                    span(class="max-w-[72px] truncate") {{selectedCollection}}
                button((click)="clearChat()", class="rounded-lg p-1.5 text-fuchsia-100/80 transition-colors hover:bg-white/10 hover:text-white", title="대화 초기화")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182")
                button((click)="toggleChat()", class="rounded-lg p-1.5 text-fuchsia-100/80 transition-colors hover:bg-white/10 hover:text-white", title="닫기")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-4")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M19.5 8.25l-7.5 7.5-7.5-7.5")

        div(*ngIf="!collectionSelected", class="flex-1 min-h-0 overflow-y-auto bg-slate-50 px-5 py-6")
            div(class="flex h-full flex-col items-center justify-center")
                div(*ngIf="collectionsLoading", class="flex flex-col items-center gap-3")
                    div(class="h-12 w-12 rounded-full border-[3px] border-cyan-400 border-t-transparent animate-spin")
                    p(class="text-[13px] text-slate-500") 데이터베이스 로딩 중...
                div(*ngIf="!collectionsLoading", class="w-full max-w-[360px]")
                    div(class="mb-6 text-center")
                        div(class="mx-auto mb-4 flex h-24 w-24 items-center justify-center rounded-[28px] border border-fuchsia-200 bg-gradient-to-br from-slate-950 via-violet-950 to-fuchsia-950 p-3 shadow-[0_20px_40px_rgba(88,28,135,0.2)]")
                            img(src="/assets/brand/plasma-robot.svg", alt="Plasma robot", class="h-full w-full rounded-[20px] object-cover")
                        p(class="text-[15px] font-semibold text-slate-900") {{robotProfile.name}}
                        p(class="mt-1 text-[12px] leading-5 text-slate-500") 논문 검색에 사용할 컬렉션을 선택하면 14단계 사고 과정을 실시간으로 보여드립니다.
                    div(*ngIf="collections.length === 0", class="rounded-2xl border border-dashed border-slate-200 bg-white px-5 py-7 text-center")
                        p(class="text-[13px] font-medium text-slate-600") 사용 가능한 컬렉션이 없습니다.
                        p(class="mt-1 text-[11px] text-slate-400") 먼저 임베딩 페이지에서 PDF를 업로드하세요.
                    div(*ngIf="collections.length > 0", class="space-y-3")
                        div(class="rounded-2xl border border-fuchsia-100 bg-fuchsia-50/60 px-4 py-3 text-[12px] text-fuchsia-800")
                            span(class="font-semibold") TRACE READY
                            span(class="ml-2 text-fuchsia-700/80") 컬렉션 선택 후 참고 문헌·유사도·도구 실행 로그를 함께 표시합니다.
                        div(class="flex flex-wrap gap-2")
                            button(*ngFor="let col of collections", (click)="selectCollection(col.name)", class="inline-flex items-center gap-2 rounded-full border px-3 py-2 text-[12px] font-medium transition-all", [ngClass]="selectedCollection === col.name ? 'border-fuchsia-500 bg-fuchsia-50 text-fuchsia-700 shadow ring-1 ring-fuchsia-200' : 'border-slate-200 bg-white text-slate-700 hover:border-fuchsia-300 hover:bg-fuchsia-50 hover:text-fuchsia-700'")
                                span(class="text-sm") 📄
                                span {{col.name}}
                                span(class="text-[10px] text-slate-400") {{col.total_docs}} docs

        div(*ngIf="collectionSelected", #chatBody="", class="flex-1 min-h-0 overflow-y-auto bg-[linear-gradient(180deg,#fdf4ff_0%,#faf5ff_48%,#f8fafc_100%)] px-4 py-4 space-y-4")
            div(*ngIf="chatMessages.length === 0", class="flex h-full flex-col items-center justify-center text-center")
                div(class="relative mb-4 flex h-24 w-24 items-center justify-center rounded-[28px] border border-fuchsia-200 bg-gradient-to-br from-slate-950 via-violet-950 to-fuchsia-950 p-3 shadow-[0_24px_50px_rgba(88,28,135,0.18)]")
                    img(src="/assets/brand/plasma-robot.svg", alt="Plasma robot", class="h-full w-full rounded-[20px] object-cover")
                p(class="text-[15px] font-semibold text-slate-900") 플라즈마 연구 플로팅 에이전트
                p(class="mt-1 max-w-[310px] text-[12px] leading-5 text-slate-500") 상단 14단계 사고과정, 참고 문헌 목록, 유사도, 도구 로그, 최종 답변을 한 흐름으로 제공합니다.
                div(class="mt-5 grid w-full max-w-[320px] gap-2")
                    button(*ngFor="let s of suggestions", (click)="sendChat(s.text)", class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 text-left text-[12px] text-slate-600 transition-all hover:border-fuchsia-300 hover:bg-fuchsia-50 hover:text-fuchsia-700")
                        span(class="text-base") {{s.icon}}
                        span(class="truncate") {{s.text}}

            ng-container(*ngFor="let msg of chatMessages; let i = index")
                div(*ngIf="msg.role === 'user'", class="flex justify-end")
                    div(class="max-w-[84%] rounded-3xl rounded-br-md bg-fuchsia-600 px-4 py-2.5 text-[13px] leading-relaxed text-white shadow-sm whitespace-pre-wrap") {{msg.content}}

                div(*ngIf="msg.role === 'assistant'", class="flex justify-start")
                    div(class="max-w-[94%] space-y-3")
                        button(*ngIf="msg.collapsed", (click)="toggleCollapse(msg)", class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-left text-[12px] text-slate-500 shadow-sm transition-colors hover:bg-slate-50")
                            div(class="flex items-center justify-between gap-3")
                                span(class="truncate") ▶ {{getCollapsedPreview(msg)}}
                                span(class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-[10px] font-medium text-slate-500") 최신 외 턴 접힘

                        ng-container(*ngIf="!msg.collapsed")
                            div(class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm")
                                button((click)="toggleTrace(msg)", class="flex w-full items-center justify-between gap-3 border-b border-slate-100 bg-slate-50/80 px-4 py-3 text-left")
                                    div(class="min-w-0")
                                        div(class="flex items-center gap-2")
                                            span(class="text-[13px] font-semibold text-slate-900") 사고 과정 (14단계)
                                            span(class="inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium", [ngClass]="getTraceStatusClasses(getCurrentTraceStep(msg)?.status || 'pending')") {{getCurrentTraceStep(msg)?.title || '준비 중'}}
                                        p(class="mt-1 text-[11px] text-slate-500") {{getCompletedTraceCount(msg)}}/14 단계 완료 · {{msg.traceCategory}} · {{msg.traceDifficulty}}
                                    span(class="text-[12px] text-slate-400") {{msg.traceOpen ? '접기' : '펼치기'}}
                                div(*ngIf="msg.traceOpen", class="space-y-2 px-4 py-4")
                                    div(*ngFor="let step of msg.traceSteps", class="rounded-2xl border px-3 py-2.5", [ngClass]="getTraceStepClasses(step)")
                                        div(class="flex items-start gap-3")
                                            div(class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-xl border border-white/70 bg-white/80 text-[11px] font-semibold text-slate-700") {{step.id}}
                                            div(class="min-w-0 flex-1")
                                                div(class="flex items-center justify-between gap-2")
                                                    div(class="flex items-center gap-2")
                                                        span(class="text-[12px] font-semibold text-slate-900") {{step.title}}
                                                        span(class="text-[11px]") {{getTraceStepIcon(step)}}
                                                    span(class="inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium", [ngClass]="getTraceStatusClasses(step.status)") {{getTraceStatusLabel(step.status)}}
                                                p(class="mt-1 text-[11px] leading-5 text-slate-600") {{step.detail || step.summary}}

                            div(class="rounded-3xl border border-sky-100 bg-sky-50/70 px-4 py-4")
                                div(class="flex items-center gap-2")
                                    span(class="inline-flex h-8 w-8 items-center justify-center rounded-2xl bg-sky-500/10 text-sky-700") ⚡
                                    div
                                        p(class="text-[12px] font-semibold text-slate-900") 현재 단계 설명
                                        p(class="text-[11px] text-slate-500") {{msg.currentLabel}}
                                p(class="mt-3 text-[12px] leading-6 text-slate-700") {{msg.currentDescription}}

                            div(class="rounded-3xl border border-fuchsia-100 bg-fuchsia-50/60 px-4 py-4")
                                div(class="mb-3 flex items-center gap-2")
                                    span(class="inline-flex h-8 w-8 items-center justify-center rounded-2xl bg-fuchsia-500/10 text-fuchsia-700") ✳️
                                    div
                                        p(class="text-[12px] font-semibold text-slate-900") 최종 답변 구성 요소
                                        p(class="text-[11px] text-slate-500") 프롬프트 + 오케스트레이터 + 도구 + 메모리 + 스트리밍 UI
                                div(class="grid gap-3 md:grid-cols-2")
                                    div(*ngFor="let component of getPipelineComponents(msg)", class="rounded-2xl border border-white/80 bg-white/90 px-3 py-3")
                                        div(class="flex items-start justify-between gap-2")
                                            div(class="min-w-0")
                                                div(class="flex items-center gap-2")
                                                    span(class="text-sm") {{component.icon}}
                                                    p(class="text-[12px] font-semibold text-slate-900") {{component.title}}
                                                p(class="mt-1 text-[11px] leading-5 text-slate-500") {{component.summary}}
                                            span(class="inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium", [ngClass]="getTraceStatusClasses(component.status)") {{getTraceStatusLabel(component.status)}}
                                        p(class="mt-3 text-[11px] leading-5 text-slate-700") {{component.detail}}
                                        div(*ngIf="component.metaBadges?.length > 0", class="mt-3 flex flex-wrap gap-1.5")
                                            span(*ngFor="let badge of component.metaBadges", class="inline-flex items-center rounded-full border border-fuchsia-100 bg-fuchsia-50 px-2 py-0.5 text-[10px] font-medium text-fuchsia-700") {{badge}}
                                        div(*ngIf="component.plan?.length > 0", class="mt-3 rounded-xl bg-slate-50 px-3 py-2")
                                            p(class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400") 오케스트레이션 계획
                                            div(class="mt-2 space-y-1")
                                                p(*ngFor="let item of component.plan", class="text-[11px] leading-5 text-slate-600") • {{item}}
                                div(*ngIf="msg.similaritySummary || msg.references.length > 0", class="mt-4 space-y-3")
                                    div(*ngIf="msg.similaritySummary", class="inline-flex items-center rounded-full border border-cyan-200 bg-white px-3 py-1 text-[11px] font-medium text-cyan-700") {{msg.similaritySummary}}
                                    div(*ngIf="msg.references.length > 0", class="rounded-2xl border border-white/80 bg-white/80 p-3")
                                        p(class="text-[11px] font-semibold text-slate-800") 참고 문헌 목록 + 유사도
                                        div(class="mt-2 space-y-2")
                                            div(*ngFor="let ref of msg.references", class="rounded-xl border border-slate-100 bg-slate-50 px-3 py-2")
                                                div(class="flex items-center justify-between gap-2")
                                                    p(class="truncate text-[11px] font-medium text-slate-800") {{ref.filename}}
                                                    span(class="inline-flex items-center rounded-full border border-cyan-200 bg-cyan-50 px-2 py-0.5 text-[10px] font-semibold text-cyan-700") sim {{formatScore(ref.score)}}
                                                p(class="mt-1 text-[10px] text-slate-500") chunk {{ref.chunk}}
                                                p(class="mt-1 text-[11px] leading-5 text-slate-600 whitespace-pre-wrap break-words") {{ref.excerpt}}

                            div(*ngIf="msg.toolCalls.length > 0", class="rounded-3xl border border-amber-100 bg-amber-50/60 px-4 py-4")
                                div(class="mb-3 flex items-center gap-2")
                                    span(class="inline-flex h-8 w-8 items-center justify-center rounded-2xl bg-amber-500/10 text-amber-700") 🧰
                                    div
                                        p(class="text-[12px] font-semibold text-slate-900") 도구 실행 로그
                                        p(class="text-[11px] text-slate-500") tool_use / tool_result 별도 카드
                                div(class="space-y-2")
                                    ng-container(*ngFor="let tc of msg.toolCalls")
                                        div(*ngIf="tc.type === 'use'", class="flex items-start gap-2 rounded-2xl border border-amber-200 bg-white px-3 py-3 text-[11px]")
                                            span(class="mt-0.5 text-sm") {{getToolIcon(tc.name)}}
                                            div(class="min-w-0 flex-1")
                                                div(class="font-semibold text-amber-700") {{getToolLabel(tc.name)}}
                                                div(*ngIf="tc.input", class="mt-1 whitespace-pre-wrap break-words text-amber-600") {{formatToolInput(tc.input)}}
                                        div(*ngIf="tc.type === 'result' && tc.name !== 'navigate_to_page'", class="flex items-start gap-2 rounded-2xl border border-emerald-200 bg-white px-3 py-3 text-[11px]")
                                            span(class="mt-0.5 text-sm") ✅
                                            div(class="min-w-0 flex-1")
                                                div(class="font-semibold text-emerald-700") {{getToolLabel(tc.name)}} 결과
                                                div(class="mt-1 whitespace-pre-wrap break-words text-emerald-600") {{parseToolResult(tc.result)}}
                                        div(*ngIf="tc.type === 'result' && tc.name === 'navigate_to_page'", class="rounded-2xl border border-cyan-300 bg-gradient-to-r from-cyan-50 to-blue-50 px-3 py-3")
                                            div(class="mb-2 flex items-center gap-2")
                                                span(class="text-lg") 🧭
                                                span(class="text-[12px] font-semibold text-cyan-800") 페이지 이동
                                            div(class="text-[12px] text-cyan-700") {{parseToolResult(tc.result)}}
                                            button((click)="navigateNow()", class="mt-3 flex w-full items-center justify-center gap-1 rounded-xl bg-cyan-600 px-3 py-2 text-[12px] font-medium text-white transition-colors hover:bg-cyan-500")
                                                span 바로 이동

                            div(*ngIf="msg.content", class="rounded-3xl border border-slate-200 bg-white px-4 py-4")
                                div(class="mb-3 flex items-center gap-2")
                                    span(class="inline-flex h-8 w-8 items-center justify-center rounded-2xl bg-indigo-500/10 text-indigo-700") 🤖
                                    div
                                        p(class="text-[12px] font-semibold text-slate-900") 최종 답변
                                        p(class="text-[11px] text-slate-500") 최신 턴만 펼쳐집니다.
                                div(class="text-[13px] leading-6 text-slate-800 whitespace-pre-wrap break-words") {{msg.content}}

            div(*ngIf="chatLoading", class="flex justify-start")
                div(class="rounded-2xl border border-slate-200 bg-white px-3 py-2.5 shadow-sm")
                    div(class="flex items-center gap-1")
                        div(class="h-2 w-2 rounded-full bg-fuchsia-400 animate-bounce", style="animation-delay: 0ms")
                        div(class="h-2 w-2 rounded-full bg-fuchsia-400 animate-bounce", style="animation-delay: 150ms")
                        div(class="h-2 w-2 rounded-full bg-fuchsia-400 animate-bounce", style="animation-delay: 300ms")

        div(*ngIf="collectionSelected", class="border-t border-slate-200 bg-white px-4 py-4")
            div(class="flex items-end gap-2")
                div(class="relative flex-shrink-0")
                    div(class="flex h-11 w-11 items-center justify-center rounded-2xl border border-fuchsia-100 bg-gradient-to-br from-slate-950 via-violet-950 to-fuchsia-950 p-1.5")
                        img(src="/assets/brand/plasma-robot.svg", alt="Plasma robot", class="h-full w-full rounded-xl object-cover")
                div(class="flex-1")
                    textarea(#chatInputEl="", [(ngModel)]="chatInput", (keydown)="onKeydown($event)", placeholder="플라즈마 관련 질문을 입력하세요...", rows="1", class="max-h-28 w-full resize-none rounded-2xl border border-slate-300 px-4 py-3 text-[13px] leading-6 text-slate-800 outline-none transition-colors focus:border-fuchsia-400 focus:ring-2 focus:ring-fuchsia-100", [disabled]="chatLoading")
                button(*ngIf="!chatLoading", (click)="sendChat()", [disabled]="!chatInput.trim()", class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-2xl bg-fuchsia-600 text-white transition-colors hover:bg-fuchsia-500 disabled:cursor-not-allowed disabled:opacity-40")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5")
                button(*ngIf="chatLoading", (click)="cancelChat()", class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-2xl bg-rose-500 text-white transition-colors hover:bg-rose-400")
                    svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="2", stroke="currentColor", class="size-4")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M5.25 7.5A2.25 2.25 0 017.5 5.25h9a2.25 2.25 0 012.25 2.25v9a2.25 2.25 0 01-2.25 2.25h-9a2.25 2.25 0 01-2.25-2.25v-9z")
