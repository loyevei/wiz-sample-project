//- 실험 관리 페이지
.flex.flex-col.w-full.h-full.overflow-auto.bg-gray-50

    //- 헤더
    .sticky.top-0.z-10.bg-white.border-b.border-gray-200.px-6.py-4.shadow-sm
        .max-w-6xl.mx-auto
            .flex.items-center.justify-between
                .flex.items-center.gap-3
                    .w-10.h-10.bg-emerald-100.rounded-lg.flex.items-center.justify-center
                        svg.w-5.h-5.text-emerald-600(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                            path(stroke-linecap="round", stroke-linejoin="round", d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5")
                    div
                        h1.text-lg.font-bold.text-gray-900 실험 관리
                        p.text-xs.text-gray-500 DOE 설계 · 실험 노트 · 레시피 관리
                button.px-4.py-2.text-sm.text-emerald-700.border.border-emerald-200.rounded-lg.bg-emerald-50.hover_bg-emerald-100.transition-colors.font-medium(
                    (click)="openDatasetPage()")
                    | 조건-결과 데이터셋

    //- 탭 내비게이션
    .max-w-6xl.mx-auto.px-6.pt-4
        .flex.gap-1.bg-gray-100.rounded-lg.p-1
            button.px-4.py-2.rounded-md.text-sm.font-medium.transition-all.duration-200(*ngFor="let tab of tabs",
                [class]="activeTab === tab.id ? 'bg-white text-emerald-700 shadow-sm' : 'text-gray-500 hover:text-gray-700'",
                (click)="switchTab(tab.id)")
                .flex.items-center.gap-2
                    svg.w-4.h-4(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                        path(stroke-linecap="round", stroke-linejoin="round", [attr.d]="tab.icon")
                    span {{ tab.label }}

    //- 탭 컨텐츠
    .max-w-6xl.mx-auto.px-6.py-6.flex-1

        //- ===== DOE 설계 탭 =====
        div(*ngIf="activeTab === 'doe'")
            .bg-white.rounded-xl.shadow-sm.border.border-gray-200.p-6.mb-6
                h2.text-base.font-semibold.text-gray-900.mb-4 실험 인자 설정
                .space-y-3
                    .flex.items-center.gap-3(*ngFor="let factor of factors; let i = index")
                        .flex-1
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="text", placeholder="인자 이름 (예: 압력)",
                                [(ngModel)]="factor.name")
                        .w-24
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="number", placeholder="최소값",
                                [(ngModel)]="factor.min")
                        .w-24
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="number", placeholder="최대값",
                                [(ngModel)]="factor.max")
                        .w-20
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="number", placeholder="수준",
                                [(ngModel)]="factor.levels", min="2", max="10")
                        button.p-2.text-red-400.hover_text-red-600.transition-colors(
                            (click)="removeFactor(i)",
                            [disabled]="factors.length <= 1")
                            svg.w-4.h-4(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                                path(stroke-linecap="round", stroke-linejoin="round", d="M6 18 18 6M6 6l12 12")

                .flex.items-center.gap-3.mt-4
                    button.px-4.py-2.text-sm.text-emerald-600.border.border-emerald-300.rounded-lg.hover_bg-emerald-50.transition-colors(
                        (click)="addFactor()")
                        | + 인자 추가
                    button.px-6.py-2.text-sm.text-white.bg-emerald-600.rounded-lg.hover_bg-emerald-700.transition-colors.font-medium(
                        (click)="generateDOE()",
                        [disabled]="doeGenerating")
                        span(*ngIf="!doeGenerating") 설계 생성
                        span(*ngIf="doeGenerating") 생성 중...

            //- DOE 결과 매트릭스
            .bg-white.rounded-xl.shadow-sm.border.border-gray-200.p-6(*ngIf="doeMatrix.length > 0")
                .flex.items-center.justify-between.mb-4
                    h2.text-base.font-semibold.text-gray-900 실험 매트릭스
                    span.text-xs.text-gray-500 총 {{ doeMatrix.length }}개 실험 조건
                .overflow-x-auto
                    table.w-full.text-sm
                        thead
                            tr.bg-gray-50
                                th.px-4.py-3.text-left.font-medium.text-gray-600 #
                                th.px-4.py-3.text-left.font-medium.text-gray-600(*ngFor="let name of getFactorNames()") {{ name }}
                                th.px-4.py-3.text-left.font-medium.text-gray-600 결과 메모
                        tbody
                            tr.border-t.border-gray-100.hover_bg-gray-50(*ngFor="let row of doeMatrix; let i = index")
                                td.px-4.py-3.text-gray-500 {{ i + 1 }}
                                td.px-4.py-3.font-mono(*ngFor="let name of getFactorNames()") {{ row[name] }}
                                td.px-4.py-3
                                    input.w-full.px-2.py-1.border.border-gray-200.rounded.text-sm(
                                        type="text", placeholder="결과 입력...",
                                        [(ngModel)]="doeResults[i]")

        //- ===== 실험 노트 탭 =====
        div(*ngIf="activeTab === 'notebook'")
            //- 검색 및 추가 버튼
            .flex.items-center.gap-3.mb-6
                .flex-1.relative
                    svg(class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400", xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                        path(stroke-linecap="round", stroke-linejoin="round", d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z")
                    input.w-full.pl-10.pr-4.py-2.border.border-gray-300.rounded-lg.text-sm(
                        type="text", placeholder="노트 검색...",
                        [(ngModel)]="noteSearch")
                button.px-4.py-2.text-sm.text-white.bg-emerald-600.rounded-lg.hover_bg-emerald-700.transition-colors.font-medium(
                    (click)="openNoteForm()")
                    | + 새 노트
                button.px-4.py-2.text-sm.text-emerald-700.border.border-emerald-200.rounded-lg.bg-emerald-50.hover_bg-emerald-100.transition-colors.font-medium(
                    (click)="generateNoteDraft()",
                    [disabled]="noteGenerating")
                    span(*ngIf="!noteGenerating") AI 노트 초안
                    span(*ngIf="noteGenerating") 초안 생성 중...

            //- 노트 폼
            .bg-white.rounded-xl.shadow-sm.border.border-gray-200.p-6.mb-6(*ngIf="showNoteForm")
                h3.text-base.font-semibold.text-gray-900.mb-4 {{ editingNote ? '노트 수정' : '새 노트 작성' }}
                .space-y-4
                    .flex.gap-4
                        .flex-1
                            label.block.text-xs.font-medium.text-gray-600.mb-1 제목
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="text", placeholder="실험 제목",
                                [(ngModel)]="noteForm.title")
                        .w-40
                            label.block.text-xs.font-medium.text-gray-600.mb-1 날짜
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="date",
                                [(ngModel)]="noteForm.date")
                    div
                        label.block.text-xs.font-medium.text-gray-600.mb-1 내용
                        textarea.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                            rows="6", placeholder="실험 내용, 조건, 관찰 결과 등을 기록하세요...",
                            [(ngModel)]="noteForm.content")
                    div
                        label.block.text-xs.font-medium.text-gray-600.mb-1 태그 (쉼표 구분)
                        input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                            type="text", placeholder="예: plasma, etching, SiO2",
                            [(ngModel)]="noteForm.tags")
                    .flex.gap-2.justify-end
                        button.px-4.py-2.text-sm.text-emerald-700.border.border-emerald-200.rounded-lg.bg-emerald-50.hover_bg-emerald-100.font-medium(
                            (click)="generateNoteDraft()",
                            [disabled]="noteGenerating")
                            span(*ngIf="!noteGenerating") 자동 초안 생성
                            span(*ngIf="noteGenerating") 생성 중...
                        button.px-4.py-2.text-sm.text-gray-600.border.border-gray-300.rounded-lg.hover_bg-gray-50(
                            (click)="cancelNoteForm()") 취소
                        button.px-4.py-2.text-sm.text-white.bg-emerald-600.rounded-lg.hover_bg-emerald-700.font-medium(
                            (click)="saveNote()") 저장

            //- 노트 목록
            .space-y-3
                .bg-white.rounded-xl.shadow-sm.border.border-gray-200.p-5.hover_border-emerald-200.transition-colors(
                    *ngFor="let note of filteredNotes()")
                    .flex.items-start.justify-between
                        div.flex-1
                            .flex.items-center.gap-2.mb-1
                                h3.text-sm.font-semibold.text-gray-900 {{ note.title }}
                                span.text-xs.text-gray-400 {{ formatDate(note.date) }}
                            p.text-sm.text-gray-600.mb-2.line-clamp-2 {{ note.content }}
                            .flex.flex-wrap.gap-1(*ngIf="note.tags")
                                span(class="px-2 py-0.5 text-xs bg-emerald-50 text-emerald-700 rounded-full", *ngFor="let tag of (note.tags || '').split(',')") {{ tag.trim() }}
                        .flex.items-center.gap-1.ml-3
                            button(class="p-1.5 text-gray-400 hover_text-emerald-600 rounded-lg hover_bg-emerald-50 transition-colors",
                                (click)="openNoteForm(note)")
                                svg.w-4.h-4(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z")
                            button(class="p-1.5 text-gray-400 hover_text-red-600 rounded-lg hover_bg-red-50 transition-colors",
                                (click)="deleteNote(note.id)")
                                svg.w-4.h-4(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0")

                //- 빈 상태
                .text-center.py-12.text-gray-400(*ngIf="filteredNotes().length === 0")
                    svg.w-12.h-12.mx-auto.mb-3.text-gray-300(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                        path(stroke-linecap="round", stroke-linejoin="round", d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z")
                    p.text-sm 실험 노트가 없습니다

        //- ===== 레시피 관리 탭 =====
        div(*ngIf="activeTab === 'recipe'")
            //- 검색 및 추가 버튼
            .flex.items-center.gap-3.mb-6
                .flex-1.relative
                    svg(class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400", xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                        path(stroke-linecap="round", stroke-linejoin="round", d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z")
                    input.w-full.pl-10.pr-4.py-2.border.border-gray-300.rounded-lg.text-sm(
                        type="text", placeholder="레시피 검색...",
                        [(ngModel)]="recipeSearch")
                button.px-4.py-2.text-sm.text-white.bg-emerald-600.rounded-lg.hover_bg-emerald-700.transition-colors.font-medium(
                    (click)="openRecipeForm()")
                    | + 새 레시피

            //- 레시피 폼
            .bg-white.rounded-xl.shadow-sm.border.border-gray-200.p-6.mb-6(*ngIf="showRecipeForm")
                h3.text-base.font-semibold.text-gray-900.mb-4 {{ editingRecipe ? '레시피 수정' : '새 레시피' }}
                .space-y-4
                    div
                        label.block.text-xs.font-medium.text-gray-600.mb-1 레시피 이름
                        input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                            type="text", placeholder="레시피 이름",
                            [(ngModel)]="recipeForm.name")
                    .grid.grid-cols-3.gap-4
                        div
                            label.block.text-xs.font-medium.text-gray-600.mb-1 가스
                            select.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                [(ngModel)]="recipeForm.gas")
                                option(value="Ar") Ar
                                option(value="O2") O₂
                                option(value="N2") N₂
                                option(value="CF4") CF₄
                                option(value="SF6") SF₆
                                option(value="Cl2") Cl₂
                                option(value="He") He
                                option(value="H2") H₂
                        div
                            label.block.text-xs.font-medium.text-gray-600.mb-1 압력 (mTorr)
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="number",
                                [(ngModel)]="recipeForm.pressure")
                        div
                            label.block.text-xs.font-medium.text-gray-600.mb-1 파워 (W)
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="number",
                                [(ngModel)]="recipeForm.power")
                    .grid.grid-cols-3.gap-4
                        div
                            label.block.text-xs.font-medium.text-gray-600.mb-1 온도 (°C)
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="number",
                                [(ngModel)]="recipeForm.temperature")
                        div
                            label.block.text-xs.font-medium.text-gray-600.mb-1 시간 (초)
                            input.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                                type="number",
                                [(ngModel)]="recipeForm.time")
                    div
                        label.block.text-xs.font-medium.text-gray-600.mb-1 설명
                        textarea.w-full.px-3.py-2.border.border-gray-300.rounded-lg.text-sm(
                            rows="3", placeholder="레시피 설명, 용도, 주의사항 등...",
                            [(ngModel)]="recipeForm.description")
                    .flex.gap-2.justify-end
                        button.px-4.py-2.text-sm.text-gray-600.border.border-gray-300.rounded-lg.hover_bg-gray-50(
                            (click)="cancelRecipeForm()") 취소
                        button.px-4.py-2.text-sm.text-white.bg-emerald-600.rounded-lg.hover_bg-emerald-700.font-medium(
                            (click)="saveRecipe()") 저장

            //- 레시피 목록
            .grid.grid-cols-1.md_grid-cols-2.gap-4
                .bg-white.rounded-xl.shadow-sm.border.border-gray-200.p-5.hover_border-emerald-200.transition-colors(
                    *ngFor="let recipe of filteredRecipes()")
                    .flex.items-start.justify-between.mb-3
                        h3.text-sm.font-semibold.text-gray-900 {{ recipe.name }}
                        .flex.items-center.gap-1
                            button.p-1.text-gray-400.hover_text-emerald-600.rounded.hover_bg-emerald-50(
                                (click)="openRecipeForm(recipe)")
                                svg(class="w-3.5 h-3.5", xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z")
                            button.p-1.text-gray-400.hover_text-red-600.rounded.hover_bg-red-50(
                                (click)="deleteRecipe(recipe.id)")
                                svg(class="w-3.5 h-3.5", xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                                    path(stroke-linecap="round", stroke-linejoin="round", d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0")
                    .grid.grid-cols-2.gap-2.text-xs
                        .flex.items-center.gap-1.text-gray-500
                            span.font-medium 가스:
                            span.text-gray-700 {{ recipe.gas }}
                        .flex.items-center.gap-1.text-gray-500
                            span.font-medium 압력:
                            span.text-gray-700 {{ recipe.pressure }} mTorr
                        .flex.items-center.gap-1.text-gray-500
                            span.font-medium 파워:
                            span.text-gray-700 {{ recipe.power }} W
                        .flex.items-center.gap-1.text-gray-500
                            span.font-medium 온도:
                            span.text-gray-700 {{ recipe.temperature }} °C
                        .flex.items-center.gap-1.text-gray-500
                            span.font-medium 시간:
                            span.text-gray-700 {{ recipe.time }} 초
                    p.text-xs.text-gray-400.mt-2.line-clamp-2(*ngIf="recipe.description") {{ recipe.description }}

            //- 빈 상태
            .text-center.py-12.text-gray-400(*ngIf="filteredRecipes().length === 0")
                svg.w-12.h-12.mx-auto.mb-3.text-gray-300(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75")
                p.text-sm 저장된 레시피가 없습니다
