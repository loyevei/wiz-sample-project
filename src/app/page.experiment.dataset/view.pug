nav(class="sticky top-0 z-20 bg-white shadow")
    div(class="max-w-6xl px-4 sm:px-6 lg:px-8 py-3")
        div(class="flex items-center justify-between")
            h1(class="flex text-lg font-semibold text-zinc-950 gap-x-3 items-center")
                svg(xmlns="http://www.w3.org/2000/svg", fill="none", viewBox="0 0 24 24", stroke-width="1.5", stroke="currentColor", class="size-6 text-emerald-600")
                    path(stroke-linecap="round", stroke-linejoin="round", d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z")
                span 실험 조건-결과 데이터셋
            button((click)="openForm()", class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-emerald-500")
                span 새 레코드

div(class="max-w-6xl pt-6 px-4 sm:px-6 lg:px-8 pb-8 space-y-6")
    div(class="bg-white rounded-xl border border-gray-200 shadow-sm p-5")
        div(class="grid grid-cols-1 md:grid-cols-4 gap-3")
            input(type="text", [(ngModel)]="searchText", placeholder="제목/메모/태그 검색", class="px-3 py-2 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-emerald-500 outline-none")
            select([(ngModel)]="selectedProjectFilter", class="px-3 py-2 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-emerald-500 outline-none")
                option(value="") 전체 프로젝트
                option(*ngFor="let project of projects", [value]="project.id") {{project.name}}
            select([(ngModel)]="selectedCollectionFilter", class="px-3 py-2 rounded-lg border border-gray-300 text-[13px] focus:ring-2 focus:ring-emerald-500 outline-none")
                option(value="") 전체 컬렉션
                option(*ngFor="let collection of collections", [value]="collection.name") {{collection.name}}
            div(class="text-[12px] text-gray-500 flex items-center justify-end") {{filteredRecords().length}}건

    div(*ngIf="filteredRecords().length === 0", class="bg-white rounded-xl border border-gray-200 shadow-sm p-10 text-center text-[13px] text-gray-400") 저장된 실험 조건-결과 레코드가 없습니다.

    div(*ngIf="filteredRecords().length > 0", class="grid grid-cols-1 lg:grid-cols-2 gap-4")
        div(*ngFor="let record of filteredRecords()", class="bg-white rounded-xl border border-gray-200 shadow-sm p-5")
            div(class="flex items-start justify-between gap-3")
                div(class="min-w-0 flex-1")
                    div(class="flex items-center gap-2 mb-1")
                        span(class="inline-flex items-center rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-semibold text-emerald-700") {{record.source_type || 'manual'}}
                        span(class="text-[10px] text-gray-400") {{record.collection || '-'}}
                    h3(class="text-[14px] font-semibold text-gray-900 truncate") {{record.title}}
                    p(class="text-[12px] text-gray-500 mt-1") 프로젝트: {{getProjectName(record.project_id)}}
                div(class="flex items-center gap-1")
                    button((click)="openForm(record)", class="p-1.5 rounded hover:bg-gray-100 text-gray-400 hover:text-emerald-600") 수정
                    button((click)="deleteRecord(record.id)", class="p-1.5 rounded hover:bg-gray-100 text-gray-400 hover:text-red-600") 삭제
            div(class="mt-4 grid grid-cols-2 gap-3")
                div(class="rounded-lg bg-gray-50 border border-gray-100 px-4 py-3")
                    div(class="text-[11px] font-semibold text-gray-700 mb-2") 조건
                    div(class="space-y-1")
                        div(*ngFor="let item of (record.conditions || []).slice(0, 4)", class="text-[12px] text-gray-600") {{item.name}}: {{item.value}}
                div(class="rounded-lg bg-gray-50 border border-gray-100 px-4 py-3")
                    div(class="text-[11px] font-semibold text-gray-700 mb-2") 결과
                    div(class="space-y-1")
                        div(*ngFor="let item of (record.outcomes || []).slice(0, 4)", class="text-[12px] text-gray-600") {{item.name}}: {{item.value}}
            div(class="mt-4")
                p(class="text-[12px] text-gray-500 line-clamp-3") {{record.notes || '메모 없음'}}
                div(class="mt-3 flex items-center justify-between")
                    div(class="flex flex-wrap gap-1.5")
                        ng-container(*ngFor="let tag of (record.tags || '').split(',')")
                            span(*ngIf="tag.trim()", class="inline-flex items-center rounded-full bg-sky-50 border border-sky-200 px-2 py-0.5 text-[10px] font-medium text-sky-700") {{tag.trim()}}
                    span(class="text-[11px] text-gray-400") {{formatDate(record.updated_at || record.created_at)}}

div(*ngIf="showForm", class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm")
    div(class="bg-white rounded-xl shadow-xl w-full max-w-3xl mx-4 overflow-hidden")
        div(class="px-6 py-5 border-b border-gray-100")
            h3(class="text-[15px] font-semibold text-gray-900") {{editingRecord ? '데이터셋 수정' : '새 데이터셋 레코드'}}
        div(class="px-6 py-6 space-y-4 max-h-[75vh] overflow-y-auto")
            div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 제목
                    input(type="text", [(ngModel)]="form.title", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 focus:outline-none")
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 소스 유형
                    select([(ngModel)]="form.source_type", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 focus:outline-none")
                        option(value="manual") manual
                        option(value="doe") doe
                        option(value="experiment-note") experiment-note
                        option(value="research-trace") research-trace
            div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 프로젝트
                    select([(ngModel)]="form.project_id", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 focus:outline-none")
                        option(value="") 선택 안 함
                        option(*ngFor="let project of projects", [value]="project.id") {{project.name}}
                div
                    label(class="block text-[13px] font-medium text-gray-700 mb-1") 컬렉션
                    select([(ngModel)]="form.collection", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 focus:outline-none")
                        option(value="") 선택 안 함
                        option(*ngFor="let collection of collections", [value]="collection.name") {{collection.name}}
            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 조건 JSON
                textarea([(ngModel)]="form.conditionsText", rows="6", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[12px] font-mono text-gray-900 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 focus:outline-none resize-none")
            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 결과 JSON
                textarea([(ngModel)]="form.outcomesText", rows="6", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[12px] font-mono text-gray-900 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 focus:outline-none resize-none")
            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 근거 참조 JSON
                textarea([(ngModel)]="form.evidenceText", rows="6", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[12px] font-mono text-gray-900 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 focus:outline-none resize-none")
            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 메모
                textarea([(ngModel)]="form.notes", rows="4", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 focus:outline-none resize-none")
            div
                label(class="block text-[13px] font-medium text-gray-700 mb-1") 태그
                input(type="text", [(ngModel)]="form.tags", class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-[13px] text-gray-900 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 focus:outline-none")
        div(class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-2")
            button((click)="cancelForm()", class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-[13px] font-medium text-gray-700 shadow-sm hover:bg-gray-50") 취소
            button((click)="saveRecord()", class="inline-flex items-center rounded-lg bg-emerald-600 px-4 py-2 text-[13px] font-semibold text-white shadow-sm hover:bg-emerald-500") 저장
